enum State: Copy + Drop {
  On: i64
  Off: i64
}

enum Level: Copy + Drop {
  High: i64
  Low: i64
}

fn chained_matches(s: State, $return: &out i64) {
  _temp_0: Level;
  a: i64;
  b: i64;
  h: i64;
  l: i64;
  entry:
    switchEnum(s) [On: switch_On_0, Off: switch_Off_1]
  switch_On_0:
    a = copy s as On;
    _temp_0 = Level::High(copy a);
    goto switch_On_0__to__switch_merge_2
  switch_On_0__to__switch_merge_2:
    drop a;
    goto switch_merge_2
  switch_Off_1:
    b = copy s as Off;
    _temp_0 = Level::Low(copy b);
    goto switch_Off_1__to__switch_merge_2
  switch_Off_1__to__switch_merge_2:
    drop b;
    goto switch_merge_2
  switch_merge_2:
    switchEnum(_temp_0) [High: switch_High_3, Low: switch_Low_4]
  switch_High_3:
    h = copy _temp_0 as High;
    $return.* = copy h;
    unborrow $return;
    goto switch_High_3__to__switch_merge_5
  switch_High_3__to__switch_merge_5:
    drop h;
    goto switch_merge_5
  switch_Low_4:
    l = copy _temp_0 as Low;
    $return.* = copy l;
    unborrow $return;
    goto switch_Low_4__to__switch_merge_5
  switch_Low_4__to__switch_merge_5:
    drop l;
    goto switch_merge_5
  switch_merge_5:
    drop _temp_0;
    drop s;
    return
}

fn loop_if_break() {
  _temp_0: unit;
  _temp_1: unit;
  _temp_2: unit;
  _temp_3: unit;
  _temp_4: unit;
  entry:
    goto loop_start_0
  loop_start_0:
    branch(true) [true: if_true_2, false: if_false_3]
  if_true_2:
    goto loop_end_1
  if_false_3:
    _temp_3 = unit;
    goto if_merge_4
  if_merge_4:
    _temp_2 = unit;
    goto if_merge_4__to__loop_start_0
  if_merge_4__to__loop_start_0:
    drop _temp_2;
    drop _temp_3;
    goto loop_start_0
  loop_end_1:
    _temp_0 = unit;
    drop _temp_0;
    return
}

struct P: Copy + Drop {
  x: i64
  y: i64
  z: i64
}

fn struct_field_diverged(c: bool, $return: &out i64) {
  p: P;
  _temp_0: unit;
  _temp_1: unit;
  _temp_2: unit;
  _temp_3: unit;
  _temp_4: unit;
  entry:
    branch(copy c) [true: if_true_0, false: if_false_1]
  if_true_0:
    p.x = 1;
    _temp_1 = unit;
    p.z = 3;
    _temp_2 = unit;
    _temp_0 = unit;
    goto if_true_0__to__if_merge_2
  if_true_0__to__if_merge_2:
    drop p.z;
    drop _temp_1;
    drop _temp_2;
    goto if_merge_2
  if_false_1:
    p.x = 1;
    _temp_3 = unit;
    p.y = 2;
    _temp_4 = unit;
    _temp_0 = unit;
    goto if_false_1__to__if_merge_2
  if_false_1__to__if_merge_2:
    drop p.y;
    drop _temp_3;
    drop _temp_4;
    goto if_merge_2
  if_merge_2:
    $return.* = copy p.x;
    unborrow $return;
    drop _temp_0;
    drop p.x;
    drop c;
    return
}
