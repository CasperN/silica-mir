# Drop-elab cross-edge insertion — regression guard for three shapes
# where an Init place (or Init sub-field) transitions to `Diverged` at
# a non-return join and must be dropped on the Init-side predecessor
# edges. A regression that narrows the fix will re-surface a leak and
# diverge this fixture's pinned MIR.
#
#   fn                       pattern                                  cross-edge drop
#   chained_matches          two postfix matches in a row             arm-bound `a`, `b`
#   loop_if_break            `if c { break }` inside `loop`           block-local unit temps
#   struct_field_diverged    heterogeneous per-field init across arms `p.y` / `p.z` per arm

# ---------- Chained postfix matches: arm bindings dropped at the inner join ----------

# The first match's arm bindings `a` / `b` are i64 (Copy), so the arm
# bodies copy them and leave the bindings Init at arm exit. The two
# arms join at `switch_merge_2`, whose terminator is the SECOND
# `switchEnum` — not `return`. Drop-elab splits both arm→merge edges
# and drops `a` / `b` there, so the eventual return sees both Uninit.
enum State: Copy + Drop { On: i64, Off: i64 }
enum Level: Copy + Drop { High: i64, Low: i64 }
fn chained_matches(s: State) -> i64 {
  s match {
    On(a) => Level::High(a),
    Off(b) => Level::Low(b),
  } match {
    High(h) => h,
    Low(l) => l,
  }
}

# ---------- `if c { break }` inside `loop`: unit temps dropped on the back edge ----------

# Inside the loop body, HLL lowering materializes the `if`'s value into
# a unit temp on each arm. The `if_merge → loop_start` back-edge is a
# non-return join; drop-elab splits it and drops the loop-body's Init
# unit temps there so successive iterations don't accumulate them.
fn loop_if_break() {
  loop {
    if true { break; };
  };
}

# ---------- Heterogeneous per-field init: arm-specific field drops ----------

# Both arms Init `p.x`, then one arm sets `p.z`, the other `p.y`. At
# the merge `p` is Partial{x: Init, y: Diverged, z: Diverged}. Drop-elab
# recurses into the Partial, plans a `drop p.z` on the true arm and a
# `drop p.y` on the false arm. Post-merge only `p.x` is Init — enough
# to satisfy the `p.x` read at return.
#
# Non-obvious invariant worth flagging cold: the destructor for `p.z`
# runs on the *true* arm — the arm that initialized it — because the
# *false* arm didn't. A field's destructor firing on this arm is
# caused by something the sibling arm didn't do. This is the only
# coherent merge semantics (the join has to agree on Init fields),
# but a future reader landing here without context will find it
# surprising. Paired negative fixture in
# `tests/init_state/partial_init/hll_partial_init_use.si` shows the
# `INIT-UseInconsistent` diagnostic that fires when a user then reads
# one of the arm-dropped fields.
struct P: Copy + Drop { x: i64, y: i64, z: i64 }
fn struct_field_diverged(c: bool) -> i64 {
  let mut p: P;
  if c {
    p.x = 1;
    p.z = 3;
  } else {
    p.x = 1;
    p.y = 2;
  }
  p.x
}
