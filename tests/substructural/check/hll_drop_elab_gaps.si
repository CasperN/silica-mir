# Drop-elab cross-edge insertion — regression guard for two patterns
# where an arm-local or block-local Init place transitions to `Diverged`
# at a non-return join and must be dropped on the Init-side predecessor
# edges. Before drop-elab visited every join (not just `return`-block
# predecessors), both fns tripped `SUB-ReturnValueLeak` at the eventual
# return; a regression that reverts the fix will re-surface the leak
# and diverge this fixture's pinned MIR.
#
#   fn                            pattern                             cross-edge drop
#   chained_matches          two postfix matches in a row        arm-bound `a`, `b`
#   loop_if_break            `if c { break }` inside `loop`      block-local unit temps

# ---------- Chained postfix matches: arm bindings dropped at the inner join ----------

# The first match's arm bindings `a` / `b` are i64 (Copy), so the arm
# bodies copy them and leave the bindings Init at arm exit. The two
# arms join at `switch_merge_2`, whose terminator is the SECOND
# `switchEnum` — not `return`. Drop-elab splits both arm→merge edges
# and drops `a` / `b` there, so the eventual return sees both Uninit.
enum State: Copy + Drop { On: i64, Off: i64 }
enum Level: Copy + Drop { High: i64, Low: i64 }
fn chained_matches(s: State) -> i64 {
  s match {
    On(a) => Level::High(a),
    Off(b) => Level::Low(b),
  } match {
    High(h) => h,
    Low(l) => l,
  }
}

# ---------- `if c { break }` inside `loop`: unit temps dropped on the back edge ----------

# Inside the loop body, HLL lowering materializes the `if`'s value into
# a unit temp on each arm. The `if_merge → loop_start` back-edge is a
# non-return join; drop-elab splits it and drops the loop-body's Init
# unit temps there so successive iterations don't accumulate them.
fn loop_if_break() {
  loop {
    if true { break; };
  };
}
