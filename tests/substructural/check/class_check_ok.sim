# Per-statement class checks accept operands of the required class.
#
# `copy p` requires `p`'s type to be Copy; `move p` requires Move;
# `drop p` requires Drop. Each fn below exercises one cell of the
# (operation x satisfying-type x operand-position) matrix. The
# operation must run clean; a regression here means the class check
# rejects a legal operand or that operand-position wiring skips a
# case.
#
# `copy` participates in every operand position (rvalue / call arg
# / enum payload) so all three are covered. `move` and `drop` only
# have a proper subset — see the header of `class_check_violations`
# for the failure-side coverage.
#
#   fn                              op    class-required   type              position
#   copy_number_as_rvalue           copy  Copy             i64               rvalue
#   copy_copy_struct_as_rvalue      copy  Copy             P (Copy+Drop)     rvalue
#   copy_shared_ref_as_rvalue       copy  Copy             &i64              rvalue
#   copy_number_as_call_arg         copy  Copy             i64               call arg
#   copy_number_as_enum_payload     copy  Copy             i64               enum payload
#   move_copy_drop_struct_via_call  move  Move             P (Copy+Drop)     call arg
#   move_move_marker_struct_rvalue  move  Move             L (Move-linear)   rvalue
#   move_mut_ref_via_call           move  Move             &mut i64          call arg
#   move_out_ref_via_call           move  Move             &out i64          call arg
#   drop_drop_struct                drop  Drop             D (Drop)          statement
#   drop_mut_ref                    drop  Drop             &mut i64          statement
#   drop_shared_ref                 drop  Drop             &i64              statement

struct P: Copy + Drop { x: i64  y: i64 }

struct L: Move { r: &out i64 }

struct D: Drop { x: i64 }

enum Wrap: Copy + Drop { W: i64 }

extern fn take_num(x: i64);
extern fn take_point(p: P);
extern fn take_mut(r: &mut i64);
extern fn take_out(r: &out i64);

# ---------- copy: Copy operand in rvalue position ----------

fn copy_number_as_rvalue(x: i64) {
  y: i64;
  entry:
    y = copy x;
    return
}

fn copy_copy_struct_as_rvalue(p: P) {
  q: P;
  entry:
    q = copy p;
    return
}

fn copy_shared_ref_as_rvalue(r: &i64) {
  s: &i64;
  entry:
    s = copy r;
    return
}

# ---------- copy: Copy operand in call-arg position ----------

fn copy_number_as_call_arg(x: i64) {
  entry:
    call take_num(copy x);
    return
}

# ---------- copy: Copy operand in enum-payload position ----------

fn copy_number_as_enum_payload(x: i64) {
  w: Wrap;
  entry:
    w = Wrap::W(copy x);
    return
}

# ---------- move: Move operand in call-arg / rvalue position ----------

# Copy+Drop implies Move, so a Copy+Drop struct is a valid `move` operand.
fn move_copy_drop_struct_via_call(p: P) {
  entry:
    call take_point(move p);
    return
}

# The `Move` marker on a linear struct discharges the `move` requirement
# even though the type is neither Copy nor Drop.
fn move_move_marker_struct_rvalue(x: L) {
  y: L;
  entry:
    y = move x;
    call take_out(move y.r);
    return
}

fn move_mut_ref_via_call(r: &mut i64) {
  entry:
    call take_mut(move r);
    return
}

fn move_out_ref_via_call(r: &out i64) {
  entry:
    call take_out(move r);
    return
}

# ---------- drop: Drop operand ----------

fn drop_drop_struct(d: D) {
  entry:
    drop d;
    return
}

fn drop_mut_ref(r: &mut i64) {
  entry:
    drop r;
    return
}

fn drop_shared_ref(r: &i64) {
  entry:
    drop r;
    return
}
