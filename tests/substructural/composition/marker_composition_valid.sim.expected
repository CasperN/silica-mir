struct CopyDropScalars: Copy + Drop {
  x: i64
  y: bool
}

struct<'s0> CopySharedRef: Copy {
  r: & 's0 i64
  x: i64
}

struct MoveScalars: Move {
  x: i64
  y: bool
}

struct<'s0, 's1, 's2, 's3, 's4> MoveAllRefKinds: Move {
  a: &mut 's0 i64
  b: &out 's1 i64
  c: &drop 's2 i64
  d: &uninit 's3 i64
  e: & 's4 i64
}

struct<'s0> DropMutRef: Drop {
  r: &mut 's0 i64
}

struct<'s0> DropUninitRef: Drop {
  r: &uninit 's0 i64
}

struct<'s0> NoMarkersLinearField {
  r: &out 's0 i64
}

struct CopyInner: Copy {
  x: i64
}

struct CopyNested: Copy {
  a: CopyInner
  y: i64
}

enum<'s0> RecursiveList: Copy + Drop {
  Nil: unit
  Cons: & 's0 RecursiveList
}

enum CopyDropScalarVariants: Copy + Drop {
  N: i64
  B: bool
  U: unit
}

struct CopyDropPoint: Copy + Drop {
  x: i64
  y: i64
}

struct MoveCopyDropField: Move {
  p: CopyDropPoint
}
