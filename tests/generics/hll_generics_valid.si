# HLL generics: parses, type-checks, and lowers to MIR end-to-end.
#
# HM inference pins the type args from context or payload:
#   - Constructor `Box { inner: 42 }` in a fn returning `Box<i64>`
#     unifies `T := i64` via the field type.
#   - Constructor `Option::Some(42)` in a fn returning `Option<i64>`
#     unifies `T := i64` via the payload.
# Field access on `b: Box<i64>` substitutes T at the access site so
# `b.inner` has type `i64`, not `T`.
# Match binding on `Option<i64>::Some(x)` gives `x: i64` via the same
# substitution.
#
# Each fn covers one cell of the (decl kind × use pattern) matrix.
#
#   fn                    decl kind  use pattern
#   make_box              struct     constructor + field access
#   box_extract           struct     field access on generic param
#   make_some             enum       constructor with payload
#   option_extract_match  enum       match with destructuring
#   nested_container      struct     nested generic (Box<Option<i64>>)
#   call_generic_fn       generic fn HM infers T := i64 from arg
#   call_generic_fn_via_ret generic fn HM infers T := i64 from return context

struct<T: Copy + Drop> Box: Copy + Drop { inner: T }

enum<T: Copy + Drop> Option: Copy + Drop { None: unit, Some: T }

# ---------- Struct: constructor + return the wrapped value ----------

# `Box { inner: 42 }` unifies `T := i64` against the return type.
fn make_box() -> Box<i64> {
  Box { inner: 42 }
}

# `b.inner` substitutes T := i64 at the field access, so the return
# type i64 matches without a mismatch diagnostic.
fn box_extract(b: Box<i64>) -> i64 {
  b.inner
}

# ---------- Enum: constructor with generic payload ----------

# `Option::Some(42)` infers `T := i64` from the payload against the
# return type `Option<i64>`.
fn make_some() -> Option<i64> {
  Option::Some(42)
}

# Match on `Option<i64>` gives payload `x: i64` — the substitution
# happens at the arm's pattern binding. `Option` is Copy+Drop, so the
# arm binding uses `copy o as V`; the scrutinee `o` stays Init and is
# dropped at the merge.
fn option_extract_match(o: Option<i64>) -> i64 {
  o match {
    None(_) => 0,
    Some(x) => x,
  }
}

# Move-only enum match: owned scrutinee dispatches to `move ml as V`
# so enum-atomicity marks `ml` Moved after the extract. Without that
# the scrutinee would stay Init at the merge and (since Move-only is
# not Drop) trip SUB-ReturnValueLeak.
enum MoveList: Move { EmptyM: unit, ConsM: i64 }
fn move_only_owned_match(ml: MoveList) -> i64 {
  ml match {
    EmptyM(u) => u_to_zero(u),
    ConsM(x) => x,
  }
}
fn u_to_zero(u: unit) -> i64 { 0 }

# Move-only enum through a shared borrow: dispatch falls back to
# `copy ml.* as V` because moving out through a shared ref would
# violate the borrow. The scrutinee stays live via the borrow.
fn move_only_borrowed_match(ml: &MoveList) -> i64 {
  ml.* match {
    EmptyM(_) => 0,
    ConsM(x) => x,
  }
}

# ---------- Nested generic ----------

# `Box<Option<i64>>` — the outer decl's arg is itself a generic
# instantiation. Extract the inner Option into a local before matching
# (variant flow only tracks root Vars, not projections).
fn nested_container(b: Box<Option<i64>>) -> i64 {
  let inner = b.inner;
  inner match {
    None(_) => 0,
    Some(x) => x,
  }
}

# Nested constructor in tail position: the inner `Box { inner: x }`
# and `Option::Some(...)` must lower into sret slots without a temp.
# Regression guard for an init-state pass that used to see fields of a
# generic struct without substituting T — deep projections (`.inner.inner`)
# then failed to fold Partial back to Init at the outer `$return`.
fn make_box_of_box(x: i64) -> Box<Box<i64>> {
  Box { inner: Box { inner: x } }
}

fn make_box_of_option(x: i64) -> Box<Option<i64>> {
  Box { inner: Option::Some(x) }
}

fn make_option_of_box(x: i64) -> Option<Box<i64>> {
  Option::Some(Box { inner: x })
}

# Nested-field READ through two levels of generic projection: `b.inner.inner`
# must type as `i64` at each hop. Regression guard for the same
# init_state / type_of_place field-substitution issue in the opposite
# direction (reads instead of writes).
fn read_nested_field(b: Box<Box<i64>>) -> i64 {
  b.inner.inner
}

# Write into pointee via a two-level generic projection: `r.*.inner.inner`.
# Exercises the `apply_pointee_write` path where each `Field` step must
# substitute the outer args to find the sub-field's concrete type.
fn write_nested_pointee(r: &out Box<Box<i64>>, x: i64) {
  r.*.inner.inner = x;
}

# Partial-move of a generic struct where the still-Init field's type
# is a substituted `Param(T)`. Drop-elab must plan `drop p.b` at
# return: `T := DropCell` is Drop, but the raw field type is `T` and
# without substitution `class_of(Param(T))` sees empty markers under
# an empty scope and silently skips the drop. This then trips
# `SUB-ReturnValueLeak`.
struct DropCell: Drop + Move { v: i64 }
struct<T: Drop + Move> DropPair: Drop + Move { a: T, b: T }

fn partial_move_generic_drop() -> DropCell {
  let p = DropPair { a: DropCell { v: 1 }, b: DropCell { v: 2 } };
  p.a
}

# ---------- Generic fn call: T inferred from argument ----------

# Each call site to `identity` freshens `T` into a new inference var,
# then unifies with the argument type. Two calls with different
# concrete args each pick their own T without interference.
fn<T: Copy + Drop> identity(x: T) -> T {
  x
}

fn call_generic_fn() -> i64 {
  identity(42.2f64);
  identity(42)
}

# ---------- Generic fn call: T inferred from return context ----------

# Here the argument is another polymorphic call whose T floats until
# the return-type annotation pins the outer call to `i64`.
fn call_generic_fn_via_ret() -> i64 {
  identity(identity(7))
}

# ---------- Unsafe block and raw pointer dereference ----------
fn test_unsafe_deref(ptr: *i64) -> i64 {
  unsafe { ptr.* }
}
