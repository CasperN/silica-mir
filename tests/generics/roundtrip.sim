# Generics — combined roundtrip fixture.
#
# Exercises every syntactic form + the scope-aware semantic checks
# that let a generic decl's marker claims be justified by its params'
# bounds:
#
# - Generic struct with a bare type-param (`struct<T>`) and no marker
#   claims — trivially valid.
# - Generic struct claiming markers, satisfied via bounds on its
#   params (`struct<T: Copy + Drop> Box: Copy + Drop { inner: T }`).
#   Decl-side check reads T's bounds through the enclosing scope, so
#   Box's Copy + Drop claim is provable.
# - Generic struct with two params carrying independent bounds
#   (`Pair<T: Copy + Drop, U: Move>`). Marker checks read `iter_declared`
#   so `Move` on U alone doesn't accidentally satisfy Copy.
# - Generic enum, decl-side + variant payload bounds
#   (`enum<T: Copy + Drop> Option: Copy + Drop`).
# - Nested type-argument reference (`Box<Box<T>>`) — the outer decl
#   has `T` in scope with bounds; the inner instantiation reuses those
#   bounds via propagation.
# - Generic function declaration (`fn<T>`), and a generic function
#   call carrying explicit type args (`call touch<i32>()`).
# - Concrete instantiation exercised through a local, so
#   `validate_type` runs its use-site bound check on `Box<i32>` — i32
#   is Copy + Drop, satisfying Box's `T: Copy + Drop` bound.

struct<T: Copy + Drop> Box: Copy + Drop { inner: T }

struct<T: Copy + Drop, U: Move> Pair { first: T second: U }

enum<T: Copy + Drop> Option: Copy + Drop { None: unit Some: T }

struct<T: Copy + Drop> Nest: Copy + Drop { outer: Box<Box<T>> }

fn<T> take_ref(r: &T) {
  entry:
    return
}

fn<T> touch() {
  entry:
    return
}

fn caller() {
  b: Box<i32>;
  entry:
    call touch<i32>();
    return
}
