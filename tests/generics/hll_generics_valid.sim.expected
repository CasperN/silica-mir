struct<T: Copy + Drop> Box: Copy + Drop {
  inner: T
}

enum<T: Copy + Drop> Option: Copy + Drop {
  None: unit
  Some: T
}

fn make_box($return: &out Box<i64>) {
  entry:
    $return.*.inner = 42;
    unborrow $return;
    return
}

fn box_extract(b: Box<i64>, $return: &out i64) {
  entry:
    $return.* = copy b.inner;
    unborrow $return;
    drop b;
    return
}

fn make_some($return: &out Option<i64>) {
  entry:
    $return.* = Option<i64>::Some(42);
    unborrow $return;
    return
}

fn option_extract_match(o: Option<i64>, $return: &out i64) {
  _: unit;
  x: i64;
  entry:
    switchEnum(o) [None: switch_None_0, Some: switch_Some_1]
  switch_None_0:
    _ = copy o as None;
    $return.* = 0;
    unborrow $return;
    goto switch_None_0__to__switch_merge_2
  switch_None_0__to__switch_merge_2:
    drop _;
    goto switch_merge_2
  switch_Some_1:
    x = copy o as Some;
    $return.* = copy x;
    unborrow $return;
    goto switch_Some_1__to__switch_merge_2
  switch_Some_1__to__switch_merge_2:
    drop x;
    goto switch_merge_2
  switch_merge_2:
    drop o;
    return
}

fn nested_container(b: Box<Option<i64>>, $return: &out i64) {
  inner: Option<i64>;
  _: unit;
  x: i64;
  entry:
    inner = move b.inner;
    switchEnum(inner) [None: switch_None_0, Some: switch_Some_1]
  switch_None_0:
    _ = copy inner as None;
    $return.* = 0;
    unborrow $return;
    goto switch_None_0__to__switch_merge_2
  switch_None_0__to__switch_merge_2:
    drop _;
    goto switch_merge_2
  switch_Some_1:
    x = copy inner as Some;
    $return.* = copy x;
    unborrow $return;
    goto switch_Some_1__to__switch_merge_2
  switch_Some_1__to__switch_merge_2:
    drop x;
    goto switch_merge_2
  switch_merge_2:
    drop inner;
    return
}

fn make_box_of_box(x: i64, $return: &out Box<Box<i64>>) {
  entry:
    $return.*.inner.inner = copy x;
    unborrow $return;
    drop x;
    return
}

fn make_box_of_option(x: i64, $return: &out Box<Option<i64>>) {
  entry:
    $return.*.inner = Option<i64>::Some(copy x);
    unborrow $return;
    drop x;
    return
}

fn make_option_of_box(x: i64, $return: &out Option<Box<i64>>) {
  _temp_0: Box<i64>;
  entry:
    _temp_0.inner = copy x;
    $return.* = Option<Box<i64>>::Some(move _temp_0);
    unborrow $return;
    drop x;
    return
}

fn read_nested_field(b: Box<Box<i64>>, $return: &out i64) {
  entry:
    $return.* = copy b.inner.inner;
    unborrow $return;
    drop b;
    return
}

fn write_nested_pointee(r: &out Box<Box<i64>>, x: i64) {
  _temp_0: unit;
  _temp_1: unit;
  entry:
    r.*.inner.inner = copy x;
    unborrow r;
    _temp_1 = unit;
    _temp_0 = unit;
    drop _temp_1;
    drop _temp_0;
    drop x;
    return
}

struct DropCell: Drop + Move {
  v: i64
}

struct<T: Drop + Move> DropPair: Drop + Move {
  a: T
  b: T
}

fn partial_move_generic_drop($return: &out DropCell) {
  p: DropPair<DropCell>;
  entry:
    p.a.v = 1;
    p.b.v = 2;
    $return.* = move p.a;
    unborrow $return;
    drop p.b;
    return
}

fn<T: Copy + Drop> identity(x: T, $return: &out T) {
  entry:
    $return.* = move x;
    unborrow $return;
    return
}

fn call_generic_fn($return: &out i64) {
  _temp_0: f64;
  _temp_1: &out f64;
  _temp_2: &out i64;
  entry:
    _temp_1 = &out _temp_0;
    call identity<f64>(42.2, move _temp_1);
    _temp_2 = &out $return.*;
    call identity<i64>(42, move _temp_2);
    unborrow $return;
    drop _temp_0;
    return
}

fn call_generic_fn_via_ret($return: &out i64) {
  _temp_0: i64;
  _temp_1: &out i64;
  _temp_2: &out i64;
  entry:
    _temp_1 = &out _temp_0;
    call identity<i64>(7, move _temp_1);
    _temp_2 = &out $return.*;
    call identity<i64>(move _temp_0, move _temp_2);
    unborrow $return;
    return
}

fn test_unsafe_deref(ptr: *i64, $return: &out i64) {
  entry:
    $return.* = copy ptr.*;
    unborrow $return;
    drop ptr;
    return
}
