# Generics — interactions with the rest of the checker.
#
# Each independent decl / fn exercises one interaction that a
# reader might expect to be brittle when `Type::Param` shows up in
# a place other analyses walk. The whole program runs clean, so any
# regression in downstream handling of Param would flip this to an
# Errors fixture.
#
# Covered:
#
# - Decl-side composition against a Param-typed field or array
#   element of a Param.
# - Recursive-through-reference (`*LL<T>`) accepted by the
#   by-value cycle check.
# - Concrete instantiation as a field of a non-generic decl:
#   use-site bound check triggers with an empty enclosing scope.
# - `type_of_place` through a projection into a generic value:
#   field access on `Box<T>` returns `T`; downcast on `Option<T>`
#   returns the variant's declared payload type (`T`).
# - `switchEnum` on a generic enum value.
# - Non-shared ref kinds carrying a Param inner: `&mut T`,
#   `&out T`, `&uninit T` — each in a body-shape that satisfies its
#   (cur, post) obligation.
# - Deref through a shared ref to a Param yields `T`.
# - Drop-elaboration on a T-typed param whose scope bounds imply
#   Drop: the elaborated MIR gets an inserted `drop x` before
#   `return`.
# - Function type carrying a Param inner (`fn(T)`).
#
# Known gap (not covered): EnumConstr for a generic enum. The MIR
# `Name::Variant(op)` syntax has no type-args form, so
# `Option::Some(copy x)` produces `Type::Custom("Option", [])`
# instead of `Option<T>` and fails to match a target of `Option<T>`.
# Extending the grammar/AST here is a follow-up.

struct<T: Copy + Drop> Box: Copy + Drop { inner: T }

enum<T: Copy + Drop> Option: Copy + Drop { None: unit  Some: T }

struct<T: Copy + Drop> LL: Copy + Drop { head: T  tail: *LL<T> }

struct Container: Copy + Drop { b: Box<i32> }

struct<T: Copy + Drop> Arr3: Copy + Drop { xs: [T; 3] }

# Move-only containers so ref-typed arguments (which are Move
# only for the linear ref kinds) can be nested inside a generic
# instantiation.
struct<T: Move> Bag: Move { inner: T }

struct<T: Move, U: Move> MovePair: Move { first: T  second: U }

struct<T: Copy + Drop, U: Copy + Drop> Pair: Copy + Drop { first: T  second: U }

# Drop-elab on a T-typed param whose scope bounds imply Drop.
fn<T: Copy + Drop> take_by_value(x: T) {
  entry:
    return
}

# Field access on a generic struct: b.inner has type T.
fn<T: Copy + Drop> access_field(b: Box<T>) {
  x: T;
  entry:
    x = copy b.inner;
    return
}

# Downcast + switchEnum on a generic enum.
fn<T: Copy + Drop> switch_on_generic_enum(o: Option<T>) {
  y: T;
  entry:
    switchEnum(o) [None: none_arm, Some: some_arm]
  none_arm:
    return
  some_arm:
    y = copy o as Some;
    return
}

# Shared ref to a Param + deref-through-ref: r.* has type T.
fn<T: Copy + Drop> read_through_shared_ref(r: &T) {
  x: T;
  entry:
    x = copy r.*;
    return
}

# &mut T (Init, Init): trivial — no obligation change needed.
fn<T: Copy + Drop> mut_ref_param(m: &mut T) {
  entry:
    return
}

# &out T (Uninit, Init): body must initialize the pointee.
fn<T: Copy + Drop> out_ref_param(src: T, dest: &out T) {
  entry:
    dest.* = copy src;
    return
}

# &uninit T (Uninit, Uninit): trivial.
fn<T: Copy + Drop> uninit_ref_param(u: &uninit T) {
  entry:
    return
}

# Fn type containing a Param inner (validated but never called).
fn<T: Copy + Drop> fn_type_with_param(f: fn(T)) {
  entry:
    return
}

# Two-level nesting: Option<Box<T>>. Each layer's bound is
# discharged by the composition-check on the layer inside it —
# Box<T> is Copy + Drop given T: Copy + Drop, and satisfies
# Option's Copy + Drop bound in turn.
fn<T: Copy + Drop> option_of_box(x: Option<Box<T>>) {
  entry:
    return
}

# Ref kinds nested inside a generic instantiation. `Bag<&mut T>`
# and `MovePair<&drop T, &out U>` both flow through the use-site
# bound check: each Move-only ref satisfies its container param's
# Move bound. Passed by shared ref because Bag / MovePair are
# themselves linear at the value level.
fn<T: Move> ref_to_bag_of_mut_ref(b: &Bag<&mut T>) {
  entry:
    return
}

# Deepest shape: a mut ref to a multi-parameter generic whose
# arguments are themselves linear-ref types. Every layer's bounds
# hold under scope-aware validation.
fn<T: Move, U: Move> mut_ref_to_pair_of_refs(p: &mut MovePair<&drop T, &out U>) {
  entry:
    return
}

# ============================================================
# Multi-block workflows.
#
# The functions below combine everything above into fn bodies of
# non-trivial algorithmic shape: switchEnum with per-arm resource
# accounting, three-step move choreography through &mut refs,
# multiple &out obligations satisfied in parallel, and branch
# terminators over Copy-typed operands.
#
# Naming caveat: without type-argument substitution, `Env::field_type`
# and `type_of_operand(FnName)` return declared types verbatim. That
# means a caller's `Foo<X>` yields `Foo`'s internally-declared T at
# field-projection sites — the two only interoperate when the outer
# type-param name coincides with the decl's. All bodies here use
# `T` (and `U`) at both layers to match; the caveat is a real limit,
# not a testing choice, and gets resolved once monomorphization
# concretizes bodies.

# switchEnum with per-arm accounting: one arm consumes the Option
# and moves the caller-supplied default; the other reads the payload
# via downcast, copies it out, then drops both remaining values.
fn<T: Copy + Drop> unwrap_or(o: Option<T>, default: T, dest: &out T) {
  entry:
    switchEnum(o) [None: use_default, Some: use_some]
  use_default:
    drop o;
    dest.* = move default;
    return
  use_some:
    dest.* = copy o as Some;
    drop o;
    drop default;
    return
}

# Three-step move choreography via two &mut refs. Only T: Move is
# required — no Copy or Drop. Every intermediate state has one
# pointee Uninit and one Init; the sequence leaves both Init.
fn<T: Move> swap(a: &mut T, b: &mut T) {
  tmp: T;
  entry:
    tmp = move a.*;
    a.* = move b.*;
    b.* = move tmp;
    return
}

# Broadcast a Copy source into two &out sinks. Both sink obligations
# transition Uninit -> Init from the same operand read.
fn<T: Copy + Drop> replicate(x: T, out_a: &out T, out_b: &out T) {
  entry:
    out_a.* = copy x;
    out_b.* = copy x;
    return
}

# Pair projection through a shared ref: reads both fields via the
# deref, copies them into distinct &out slots of matching type. The
# whole flow works because `p: &Pair<T, U>` never gets consumed —
# NLL inserts an `unborrow p` after the last field read.
fn<T: Copy + Drop, U: Copy + Drop> pair_copy_out(
  p: &Pair<T, U>,
  out_first: &out T,
  out_second: &out U,
) {
  entry:
    out_first.* = copy p.*.first;
    out_second.* = copy p.*.second;
    return
}

# branch on a bool operand, choose between two Copy+Drop candidates.
# Each arm clears the unused candidate with `drop`, so the fn's
# net effect is one write to `dest` plus symmetric cleanup on
# both branches.
fn<T: Copy + Drop> pick_by_flag(flag: bool, a: T, b: T, dest: &out T) {
  entry:
    branch (copy flag) [true: pick_a, false: pick_b]
  pick_a:
    dest.* = copy a;
    drop a;
    drop b;
    return
  pick_b:
    dest.* = copy b;
    drop a;
    drop b;
    return
}

# Pull a T out of a generic Box, then consume the Box. Exercises
# field projection on an owned generic value across a stmt boundary:
# the copy leaves `b` still Init, and the explicit drop closes it
# out. Confirms that generic-struct owned-value flow composes with
# both a Copy field-read and a whole-value Drop.
fn<T: Copy + Drop> unbox(b: Box<T>, dest: &out T) {
  entry:
    dest.* = copy b.inner;
    drop b;
    return
}
