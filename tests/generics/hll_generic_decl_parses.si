# HLL generic decl parses and lowers to MIR cleanly.
#
# `struct<T: Copy + Drop> Box: Copy + Drop { inner: T }` — the parser
# resolves `T` in the field type to `Type::Param("T")` because it is
# in the enclosing decl's type-parameter scope. Lowering copies the
# type-parameter clause through to the MIR decl, where the existing
# generics support handles the composition check.
#
# Fn generics have the same shape and lower identically.

struct<T: Copy + Drop> Box: Copy + Drop { inner: T }

enum<T: Copy + Drop> Option: Copy + Drop { None: unit, Some: T }

fn f() {
}
