struct<T: Copy + Drop> Box: Copy + Drop {
  inner: T
}

struct<T: Copy + Drop, U: Move> Pair {
  first: T
  second: U
}

enum<T: Copy + Drop> Option: Copy + Drop {
  None: unit
  Some: T
}

struct<T: Copy + Drop> Nest: Copy + Drop {
  outer: Box<Box<T>>
}

struct<T: Copy + Drop> LL: Copy + Drop {
  head: T
  tail: *LL<T>
}

struct Container: Copy + Drop {
  b: Box<i32>
}

struct<T: Copy + Drop> Arr3: Copy + Drop {
  xs: [T; 3]
}

struct<T: Move> Bag: Move {
  inner: T
}

struct<T: Move, U: Move> MovePair: Move {
  first: T
  second: U
}

struct<T: Copy + Drop, U: Copy + Drop> CopyPair: Copy + Drop {
  first: T
  second: U
}

fn<'s0, T> take_ref(r: & 's0 T) {
  entry:
    unborrow r;
    return
}

fn<T> touch() {
  entry:
    return
}

fn caller() {
  b: Box<i32>;
  entry:
    call touch<i32>();
    return
}

fn<T: Copy + Drop> take_by_value(x: T) {
  entry:
    drop x;
    return
}

fn<T: Copy + Drop> access_field(b: Box<T>) {
  x: T;
  entry:
    x = copy b.inner;
    drop x;
    drop b;
    return
}

fn<T: Copy + Drop> switch_on_generic_enum(o: Option<T>) {
  y: T;
  entry:
    switchEnum(o) [None: none_arm, Some: some_arm]
  none_arm:
    drop o;
    return
  some_arm:
    y = copy o as Some;
    drop y;
    drop o;
    return
}

fn<'s0, T: Copy + Drop> read_through_shared_ref(r: & 's0 T) {
  x: T;
  entry:
    x = copy r.*;
    unborrow r;
    drop x;
    return
}

fn<'s0, T: Copy + Drop> mut_ref_param(m: &mut 's0 T) {
  entry:
    unborrow m;
    return
}

fn<'s0, T: Copy + Drop> out_ref_param(src: T, dest: &out 's0 T) {
  entry:
    dest.* = copy src;
    unborrow dest;
    drop src;
    return
}

fn<'s0, T: Copy + Drop> uninit_ref_param(u: &uninit 's0 T) {
  entry:
    unborrow u;
    return
}

fn<T: Copy + Drop> fn_type_with_param(f: fn(T)) {
  entry:
    drop f;
    return
}

fn<T: Copy + Drop> option_of_box(x: Option<Box<T>>) {
  entry:
    drop x;
    return
}

fn<'s0, 's1, T: Move> ref_to_bag_of_mut_ref(b: & 's0 Bag<&mut 's1 T>) {
  entry:
    unborrow b;
    return
}

fn<'s0, 's1, 's2, T: Move, U: Move> mut_ref_to_pair_of_refs(p: &mut 's0 MovePair<&drop 's1 T, &out 's2 U>) {
  entry:
    unborrow p;
    return
}

fn<'s0, T: Copy + Drop> unwrap_or(o: Option<T>, default: T, dest: &out 's0 T) {
  entry:
    switchEnum(o) [None: use_default, Some: use_some]
  use_default:
    drop o;
    dest.* = move default;
    unborrow dest;
    return
  use_some:
    dest.* = copy o as Some;
    unborrow dest;
    drop o;
    drop default;
    return
}

fn<'s0, 's1, T: Move> swap(a: &mut 's0 T, b: &mut 's1 T) {
  tmp: T;
  entry:
    tmp = move a.*;
    a.* = move b.*;
    unborrow a;
    b.* = move tmp;
    unborrow b;
    return
}

fn<'s0, 's1, T: Copy + Drop> replicate(x: T, out_a: &out 's0 T, out_b: &out 's1 T) {
  entry:
    out_a.* = copy x;
    unborrow out_a;
    out_b.* = copy x;
    unborrow out_b;
    drop x;
    return
}

fn<'s0, 's1, 's2, T: Copy + Drop, U: Copy + Drop> pair_copy_out(p: & 's0 CopyPair<T, U>, out_first: &out 's1 T, out_second: &out 's2 U) {
  entry:
    out_first.* = copy p.*.first;
    unborrow out_first;
    out_second.* = copy p.*.second;
    unborrow out_second;
    unborrow p;
    return
}

fn<'s0, T: Copy + Drop> pick_by_flag(flag: bool, a: T, b: T, dest: &out 's0 T) {
  entry:
    branch(copy flag) [true: pick_a, false: pick_b]
  pick_a:
    dest.* = copy a;
    unborrow dest;
    drop a;
    drop b;
    drop flag;
    return
  pick_b:
    dest.* = copy b;
    unborrow dest;
    drop a;
    drop b;
    drop flag;
    return
}

fn<'s0, T: Copy + Drop> unbox(b: Box<T>, dest: &out 's0 T) {
  entry:
    dest.* = copy b.inner;
    unborrow dest;
    drop b;
    return
}
