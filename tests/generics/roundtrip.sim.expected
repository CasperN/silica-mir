struct<T: Copy + Drop> Box: Copy + Drop {
  inner: T
}

struct<T: Copy + Drop, U: Move> Pair {
  first: T
  second: U
}

enum<T: Copy + Drop> Option: Copy + Drop {
  None: unit
  Some: T
}

struct<T: Copy + Drop> Nest: Copy + Drop {
  outer: Box<Box<T>>
}

fn<T> take_ref(r: & T) {
  entry:
    unborrow r;
    return
}

fn<T> touch() {
  entry:
    return
}

fn caller() {
  b: Box<i32>;
  entry:
    call touch<i32>();
    return
}
