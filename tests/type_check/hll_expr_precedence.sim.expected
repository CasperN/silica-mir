fn assign_rhs_binop($return: &out i64) {
  x: i64;
  _temp_0: unit;
  _temp_1: i64;
  _temp_2: &out i64;
  entry:
    x = 0;
    _temp_2 = &out _temp_1;
    call $i64_add(copy x, 1, move _temp_2);
    drop x;
    x = move _temp_1;
    _temp_0 = unit;
    $return.* = copy x;
    unborrow $return;
    drop _temp_0;
    drop x;
    return
}

