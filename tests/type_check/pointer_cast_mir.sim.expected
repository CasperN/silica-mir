fn<'s0> ptr_to_ptr(p: *i64, $return: &out 's0 *u8) {
  entry:
    $return.* = ptr_cast(copy p, *u8);
    unborrow $return;
    drop p;
    return
}

fn<'s0, 's1> ref_to_ptr(r: & 's0 i64, $return: &out 's1 *u8) {
  entry:
    $return.* = ptr_cast(copy r, *u8);
    unborrow $return;
    unborrow r;
    return
}

fn<'s0, 's1> ptr_to_ref(p: *i64, $return: &out 's0 & 's1 i64) {
  entry:
    $return.* = ptr_cast(copy p, & i64);
    unborrow $return;
    drop p;
    return
}

fn<'s0, 's1> ref_to_ref(r: & 's0 i64, $return: &out 's1 & 's0 u8) {
  entry:
    $return.* = ptr_cast(copy r, & u8);
    unborrow $return;
    unborrow r;
    return
}

fn<'s0, 's1> mut_ref_to_mut_ptr(r: &mut 's0 i64, $return: &out 's1 *u8) {
  _temp_0: *i64;
  entry:
    _temp_0 = &raw r.*;
    unborrow r;
    $return.* = ptr_cast(move _temp_0, *u8);
    unborrow $return;
    return
}

fn<'s0, 's1> mut_ptr_to_mut_ref(p: *i64, $return: &out 's0 &mut 's1 i64) {
  entry:
    $return.* = ptr_cast(copy p, &mut i64);
    unborrow $return;
    drop p;
    return
}

fn<'s0, 's1> mut_ref_to_mut_ref(r: &mut 's0 i64, $return: &out 's1 &mut 's0 u8) {
  _temp_0: *u8;
  _temp_1: *i64;
  entry:
    _temp_1 = &raw r.*;
    unborrow r;
    _temp_0 = ptr_cast(move _temp_1, *u8);
    $return.* = ptr_cast(move _temp_0, &mut u8);
    unborrow $return;
    return
}
