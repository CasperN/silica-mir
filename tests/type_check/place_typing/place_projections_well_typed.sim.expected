struct P: Copy + Drop {
  x: i64
  y: i64
}

struct Ptr: Copy + Drop {
  r: & i64
}

enum Option: Copy + Drop {
  None: unit
  Some: i64
}

fn read_var_scalar(x: i64) {
  y: i64;
  entry:
    y = copy x;
    drop y;
    drop x;
    return
}

fn noop() {
  entry:
    return
}

fn read_var_fn_pointer() {
  g: fn();
  entry:
    g = noop;
    call copy g();
    drop g;
    return
}

fn field_on_struct(p: P) {
  a: i64;
  entry:
    a = copy p.x;
    drop a;
    drop p;
    return
}

fn downcast_on_enum(o: Option) {
  x: i64;
  entry:
    switchEnum(o) [None: n, Some: s]
  s:
    x = copy o as Some;
    drop x;
    drop o;
    return
  n:
    drop o;
    return
}

fn deref_of_ref(r: & i64) {
  x: i64;
  entry:
    x = copy r.*;
    unborrow r;
    drop x;
    return
}

fn deref_of_nested_ref(r: &mut &mut i64) {
  a: i64;
  entry:
    a = copy r.*.*;
    unborrow r;
    drop a;
    return
}

fn deref_through_field(p: Ptr) {
  a: i64;
  entry:
    a = copy p.r.*;
    unborrow p.r;
    drop a;
    return
}
