# HLL parse-shape stress. Two concerns bundled here because they both
# pin edges of `grammar.js` that don't have another natural home:
#   * expression precedence and associativity;
#   * block-like expressions usable as statements without `;`
#     (Rust's `ExpressionWithBlock` rule).
# A regression in either surfaces as a lowering mismatch.
#
# Precedence ladder (loose → tight): assignment → equality → comparison
# → additive → multiplicative → borrow → postfix → primary.

# ---------- assignment RHS is a binary_expr ----------

# Reassigning a mutable local with a binop that references the same
# place: RHS must be evaluated before the assignment lands. Before the
# grammar fix, this parsed as `(x = x) + 1`.
fn assign_rhs_binop() -> i64 {
  let mut x = 0;
  x = x + 1;
  x
}

# ---------- additive is left-associative ----------

# `a - b - c` = `(a - b) - c`. If prec.left were dropped, this would
# associate right and the returned value would differ.
fn additive_left_assoc(a: i64, b: i64, c: i64) -> i64 {
  a - b - c
}

# ---------- multiplicative binds tighter than additive ----------

# `a + b * c` = `a + (b * c)` because `*` sits at prec 13, `+` at 12.
fn mul_over_add(a: i64, b: i64, c: i64) -> i64 {
  a + b * c
}

# ---------- comparison binds looser than additive ----------

# `a + b < c + d` = `(a + b) < (c + d)`. If additive were looser than
# comparison, the `+` in the LHS would swallow the `<`.
fn cmp_over_add(a: i64, b: i64, c: i64, d: i64) -> bool {
  a + b < c + d
}

# ---------- borrow binds tighter than any binary op ----------

# `&x` binds tighter than `+`, so `read(&x)` still parses as a call
# with a borrow-typed argument even when the return is used in a
# binary op. Regression guard for the borrow_expr precedence bump
# alongside the `binary_expr` operand fix.
fn read(r: &i64) -> i64 { r.* }
fn borrow_tighter_than_add(x: i64, y: i64) -> i64 {
  read(&x) + y
}

# ---------- block-like expressions as statements without `;` ----------

# `if E { ... } else { ... }` as an intermediate statement — the parser
# accepts it without a trailing `;` because the expression ends in `}`.
fn if_as_stmt(a: i64, r: &out i64) {
  if a > 0 { r.* = 1 } else { r.* = 2 }
}

# `if` at the tail (with a value) is still parsed as the block's
# trailing expression, so both roles coexist under one grammar.
fn if_as_tail(a: i64) -> i64 {
  let base = 10;
  if a > 0 { base } else { 0 }
}

# `loop { ... }` and empty block `{ }` in sequence as statements.
fn loop_and_block_as_stmts() {
  loop { break }
  { }
}

# Postfix `x match { arms }` as a statement (block-like ends in `}`).
enum Tag: Copy + Drop { A: i64, B: i64 }
fn match_as_stmt(t: Tag, r: &out i64) {
  t match {
    A(x) => r.* = x,
    B(y) => r.* = y,
  }
}

# Postfix chain on a match result — `x match { ... } .foo` should still
# parse as a chain, not treat the match as a terminal statement. Uses
# a field-access placeholder since UFCS method calls aren't in yet.
struct Wrap: Copy + Drop { inner: i64 }
fn postfix_chain_on_match(t: Tag) -> i64 {
  let w = t match {
    A(x) => Wrap { inner: x },
    B(y) => Wrap { inner: y },
  };
  w.inner
}

# Chained postfix matches parse correctly (see `chained_matches_leak`
# in `tests/substructural/hll_diagnostics_sub.si`) — the parse-shape
# aspect of this idiom is guaranteed by prec(-1) on `_block_like_stmt`,
# but the resulting MIR trips a separate drop-elab bug that lives in a
# substructural fixture, not here.
