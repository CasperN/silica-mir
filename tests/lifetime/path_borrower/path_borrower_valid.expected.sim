struct<'s0> RefBox: Move {
  p: &mut 's0 i64
}

struct<'s0, 's1> RefBox2: Move {
  q: &mut 's0 i64
  r: &mut 's1 i64
}

struct<'s0> Linear: Move {
  r: &out 's0 i64
}

extern fn use_mut(r: &mut 's0 i64);

extern fn sink(r: &mut 's0 i64);

extern fn take_box(b: RefBox);

extern fn sink_linear(y: Linear);

fn split_fields_independent(x: i64, y: i64) {
  b: RefBox2;
  entry:
    b.q = &mut x;
    b.r = &mut y;
    call use_mut(move b.q);
    call use_mut(move b.r);
    drop y;
    drop x;
    return
}

fn reborrow_through_field(x: i64) {
  b: RefBox;
  s: &mut i64;
  entry:
    b.p = &mut x;
    s = &mut b.p.*;
    call sink(move s);
    call take_box(move b);
    drop x;
    return
}

fn move_ancestor_closes_loans(x: i64) {
  b: RefBox;
  entry:
    b.p = &mut x;
    call take_box(move b);
    drop x;
    x = 1;
    drop x;
    return
}

fn whole_struct_move_survives_loan(x: i64) {
  b: RefBox;
  entry:
    b.p = &mut x;
    call take_box(move b);
    drop x;
    return
}

fn struct_with_ref_typed_field(x: Linear) {
  y: Linear;
  entry:
    y = move x;
    call sink_linear(move y);
    return
}

fn fulfilled_field_ref_before_move(x: i64, z: i64) {
  b: RefBox;
  y: i64;
  entry:
    b.p = &mut x;
    y = move b.p.*;
    b.p.* = 7;
    call take_box(move b);
    drop y;
    drop z;
    drop x;
    return
}
