# Path-borrower pass — transfer of an unfulfilled field-ref obligation.
#
# Moving a struct transfers every reference-field obligation to the callee,
# just as moving a bare reference does. The caller must not be forced to
# fulfill the obligation before transferring ownership of the container.

struct RefBox: Move { p: &mut i64 }

extern fn take_box(b: RefBox);

# ---------- Move struct before field-ref obligation is met ----------

# `b.p = &mut x` opens a loan that imposes an Init obligation: the
# pointee must be Init when `b.p` expires. Moving `b.p.*` out without
# writing back leaves `x` Uninit. Moving `b` via `take_box` transfers
# that outstanding obligation to the callee, so the caller is valid.
fn move_with_unfulfilled_ref_obs(x: i64) {
  b: RefBox;
  y: i64;
  entry:
    b.p = &mut x;
    y = move b.p.*;
    call take_box(move b);
    return
}
