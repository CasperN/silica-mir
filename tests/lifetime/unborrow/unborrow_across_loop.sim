
        extern fn use_num(n: i64);
        fn f(x: i64, b: bool) {
          r: &mut i64;
          entry:
            r = &mut x;
            goto head
          head:
            branch(copy b) [true: body, false: done]
          body:
            call use_num(copy r.*);
            goto head
          done:
            unborrow r;
            x = 42;
            return
        }
        