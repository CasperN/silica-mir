fn f(a: i64, b: i64, c: bool) {
  r: &mut i64;
  entry:
    branch(copy c) [true: t, false: fbr]
  t:
    r = &mut a;
    unborrow r;
    goto merge
  fbr:
    r = &mut b;
    unborrow r;
    goto merge
  merge:
    drop a;
    a = 1;
    drop b;
    b = 2;
    drop c;
    drop b;
    drop a;
    return
}
