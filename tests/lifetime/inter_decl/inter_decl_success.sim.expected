fn<'a, 's0> identity(r: & 'a i64, $return: &out 's0 & 'a i64) {
  entry:
    $return.* = copy r;
    unborrow $return;
    unborrow r;
    return
}

fn<'a, 's0> pick(x: & 'a i64, y: & 'a i64, $return: &out 's0 & 'a i64) {
  entry:
    unborrow y;
    $return.* = copy x;
    unborrow $return;
    unborrow x;
    return
}

fn<'a, 'b, 's0> first(x: & 'a i64, y: & 'b i64, $return: &out 's0 & 'a i64) {
  entry:
    unborrow y;
    $return.* = copy x;
    unborrow $return;
    unborrow x;
    return
}

fn<'a, 'b, 's0> second(x: & 'a i64, y: & 'b i64, $return: &out 's0 & 'b i64) {
  entry:
    unborrow x;
    $return.* = copy y;
    unborrow $return;
    unborrow y;
    return
}

struct<'a> Wrap: Move {
  r: & 'a i64
}

fn<'a, 's0> wrap_it(x: & 'a i64, $return: &out 's0 Wrap<'a>) {
  entry:
    $return.*.r = copy x;
    unborrow $return;
    unborrow x;
    return
}

struct<'a, 'b> Both: Move {
  l: & 'a i64
  r: & 'b i64
}

fn<'a, 'b, 's0> make_both(x: & 'a i64, y: & 'b i64, $return: &out 's0 Both<'a, 'b>) {
  entry:
    $return.*.l = copy x;
    unborrow x;
    $return.*.r = copy y;
    unborrow $return;
    unborrow y;
    return
}

enum<'a> MaybeRef: Copy + Drop {
  None: unit
  Some: & 'a i64
}

fn<'a, 's0> maybe_of(r: & 'a i64, $return: &out 's0 MaybeRef<'a>) {
  entry:
    $return.* = MaybeRef::Some(copy r);
    unborrow $return;
    unborrow r;
    return
}

fn use_identity() {
  x: i64;
  r: & i64;
  ret_slot: & i64;
  ret_out: &out & i64;
  read: i64;
  entry:
    x = 42;
    r = & x;
    ret_out = &out ret_slot;
    call identity(move r, move ret_out);
    read = copy ret_slot.*;
    unborrow ret_slot;
    drop read;
    drop x;
    return
}

extern fn use_wrap(w: Wrap);

fn<'a> local_wrap_consumed(x: & 'a i64) {
  w: Wrap<'a>;
  entry:
    w.r = copy x;
    unborrow x;
    call use_wrap(move w);
    return
}

fn<'a, 's0> write_through_out(dst: &out 's0 & 'a i64, src: & 'a i64) {
  entry:
    dst.* = copy src;
    unborrow dst;
    unborrow src;
    return
}

fn<'a, 's0> wrap_ref_in_enum(r: & 'a i64, $return: &out 's0 MaybeRef<'a>) {
  entry:
    $return.* = MaybeRef::Some(copy r);
    unborrow $return;
    unborrow r;
    return
}
