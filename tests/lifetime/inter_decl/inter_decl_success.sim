# Success cases for inter-decl (cross-fn / cross-struct) lifetimes.
# Every function here should type-check and lifetime-check cleanly.
# Once the loan checker honors declared lifetimes, these must still
# succeed — they pin every shape the analysis should accept.
#
# Axes covered:
#   - fn ref-return with one input       (elision applies)
#   - fn ref-return with multiple inputs (explicit lifetimes)
#   - struct with one ref field
#   - struct with two ref fields (independent lifetimes)
#   - enum with ref-carrying variant
#   - cross-fn ref-return threading

# ---------- fn returning a ref from a single input (explicit) ----------

# Single-ref input, single-ref output. Explicit 'a ties input to
# output so the returned ref's region matches the input's. Silica
# elision synthesizes a distinct fresh lifetime per unannotated ref
# (no Rust-style rule-2 unification), so the caller must write 'a
# whenever they want two refs to share a region.
fn<'a> identity(r: &'a i64, $return: &out &'a i64) {
  entry:
    $return.* = copy r;
    return
}

# ---------- explicit single-lifetime: two inputs share 'a ----------

# Both inputs share 'a; result borrows from either. Classic Rust
# max-style shape.
fn<'a> pick(x: &'a i64, y: &'a i64, $return: &out &'a i64) {
  entry:
    $return.* = copy x;
    return
}

# ---------- explicit multi-lifetime: distinct 'a and 'b ----------

# Two independent lifetimes; return tied to 'a only.
fn<'a, 'b> first(x: &'a i64, y: &'b i64, $return: &out &'a i64) {
  entry:
    $return.* = copy x;
    return
}

# Same shape, returning the 'b side.
fn<'a, 'b> second(x: &'a i64, y: &'b i64, $return: &out &'b i64) {
  entry:
    $return.* = copy y;
    return
}

# ---------- struct with one ref field ----------

# 'a threads through the field. The struct is Move (linear over the
# ref); passing it forward is the only discharge.
struct<'a> Wrap: Move { r: &'a i64 }

fn<'a> wrap_it(x: &'a i64, $return: &out Wrap<'a>) {
  entry:
    $return.*.r = copy x;
    return
}

# ---------- struct with two independent ref lifetimes ----------

struct<'a, 'b> Both: Move { l: &'a i64, r: &'b i64 }

fn<'a, 'b> make_both(x: &'a i64, y: &'b i64, $return: &out Both<'a, 'b>) {
  entry:
    $return.*.l = copy x;
    $return.*.r = copy y;
    return
}

# ---------- enum with ref-carrying variant ----------

enum<'a> MaybeRef: Copy + Drop { None: unit, Some: &'a i64 }

fn<'a> maybe_of(r: &'a i64, $return: &out MaybeRef<'a>) {
  entry:
    $return.* = MaybeRef::Some(copy r);
    return
}

# ---------- caller wires ref through returned-ref chain ----------

# Caller borrows a local, passes through identity, and uses the
# result. The loan on x stays live from the borrow to the last
# access through the returned ref.
fn use_identity() {
  x: i64;
  r: &'a i64;
  ret_slot: &'a i64;
  ret_out: &out &'a i64;
  read: i64;
  entry:
    x = 42;
    r = &x;
    ret_out = &out ret_slot;
    call identity(move r, move ret_out);
    read = copy ret_slot.*;
    return
}

# ---------- body-local Wrap not stored anywhere: no escape ----------

# Move the caller-provided ref into a locally-declared Wrap, then
# consume the Wrap via extern. Nothing escapes past return.
extern fn use_wrap(w: Wrap);

fn<'a> local_wrap_consumed(x: &'a i64) {
  w: Wrap<'a>;
  entry:
    w.r = copy x;
    call use_wrap(move w);
    return
}

# ---------- write through &out param, source is caller's ref ----------

# Writing a caller-provided ref through a caller-provided &out slot.
# Source region 'a matches destination region 'a; escape check
# permits it because the source is signature-visible.
fn<'a> write_through_out(dst: &out &'a i64, src: &'a i64) {
  entry:
    dst.* = copy src;
    return
}

# ---------- enum with ref variant, wrapped and returned ----------

fn<'a> wrap_ref_in_enum(r: &'a i64, $return: &out MaybeRef<'a>) {
  entry:
    $return.* = MaybeRef::Some(copy r);
    return
}
