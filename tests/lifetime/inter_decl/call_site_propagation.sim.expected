fn<'a, 's0> identity(r: & 'a i64, $return: &out 's0 & 'a i64) {
  entry:
    $return.* = copy r;
    unborrow $return;
    unborrow r;
    return
}

fn caller_writes_through_input_alias() {
  x: i64;
  r: & i64;
  ret_slot: & i64;
  ret_out: &out & i64;
  read: i64;
  entry:
    x = 1;
    r = & x;
    ret_out = &out ret_slot;
    call identity(move r, move ret_out);
    drop x;
    x = 2;
    read = copy ret_slot.*;
    unborrow ret_slot;
    drop read;
    drop x;
    return
}

fn<'a> take_ref(r: & 'a i64) {
  entry:
    unborrow r;
    return
}

fn caller_passes_through() {
  x: i64;
  r: & i64;
  entry:
    x = 1;
    r = & x;
    call take_ref(move r);
    drop x;
    x = 2;
    drop x;
    return
}

fn<'a, 's0> make_ref(seed: & 'a i64, $return: &out 's0 & 'a i64) {
  entry:
    $return.* = copy seed;
    unborrow $return;
    unborrow seed;
    return
}

fn caller_uses_make_ref() {
  seed: i64;
  s: & i64;
  ret_slot: & i64;
  ret_out: &out & i64;
  read: i64;
  entry:
    seed = 7;
    s = & seed;
    ret_out = &out ret_slot;
    call make_ref(move s, move ret_out);
    drop seed;
    seed = 99;
    read = copy ret_slot.*;
    unborrow ret_slot;
    drop read;
    drop seed;
    return
}
