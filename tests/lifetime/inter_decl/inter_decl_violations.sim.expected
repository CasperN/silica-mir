struct<'a> Wrap: Move {
  r: & 'a i64
}

fn<'a> dangling_return(dummy: & 'a i64, $return: &out & 'a i64) {
  x: i64;
  entry:
    unborrow dummy;
    x = 42;
    $return.* = & x;
    unborrow $return;
    drop x;
    return
}

fn<'a, 'b> wrong_lifetime_side(x: & 'a i64, y: & 'b i64, $return: &out & 'a i64) {
  entry:
    unborrow x;
    $return.* = copy y;
    unborrow $return;
    unborrow y;
    return
}

fn escape_struct_lifetime(caller_ref: & i64, $return: &out Wrap) {
  local: i64;
  entry:
    unborrow caller_ref;
    local = 1;
    $return.*.r = & local;
    unborrow $return;
    drop local;
    return
}

fn<'a> reborrow_escape($return: &out Wrap) {
  x: i64;
  w: Wrap;
  entry:
    x = 7;
    w.r = & x;
    $return.* = move w;
    unborrow $return;
    drop x;
    return
}
