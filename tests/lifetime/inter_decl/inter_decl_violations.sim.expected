struct<'a> Wrap: Move {
  r: & 'a i64
}

fn<'a, 's0> dangling_return(dummy: & 'a i64, $return: &out 's0 & 'a i64) {
  x: i64;
  entry:
    unborrow dummy;
    x = 42;
    $return.* = & x;
    unborrow $return;
    drop x;
    return
}

fn<'a, 'b, 's0> wrong_lifetime_side(x: & 'a i64, y: & 'b i64, $return: &out 's0 & 'a i64) {
  entry:
    unborrow x;
    $return.* = copy y;
    unborrow $return;
    unborrow y;
    return
}

fn<'s0, 's1> escape_struct_lifetime(caller_ref: & 's0 i64, $return: &out 's1 Wrap) {
  local: i64;
  entry:
    unborrow caller_ref;
    local = 1;
    $return.*.r = & local;
    unborrow $return;
    drop local;
    return
}

fn<'a, 's0> reborrow_escape($return: &out 's0 Wrap<'a>) {
  x: i64;
  w: Wrap<'a>;
  entry:
    x = 7;
    w.r = & x;
    $return.* = move w;
    unborrow $return;
    drop x;
    return
}
