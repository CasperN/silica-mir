fn<'s0, 's1, 's2> identity(r: & 's0 i64, $return: &out 's1 & 's2 i64) {
  entry:
    $return.* = copy r;
    unborrow $return;
    unborrow r;
    return
}

fn<'s0, 's1, 's2, 's3> pick_first(x: & 's0 i64, y: & 's1 i64, $return: &out 's2 & 's3 i64) {
  entry:
    unborrow y;
    $return.* = copy x;
    unborrow $return;
    unborrow x;
    return
}

fn<'s0, 's1, 's2, 's3> pick_second(x: & 's0 i64, y: & 's1 i64, $return: &out 's2 & 's3 i64) {
  entry:
    unborrow x;
    $return.* = copy y;
    unborrow $return;
    unborrow y;
    return
}

fn<'a, 's0, 's1, 's2> mixed_elision(x: & 'a i64, y: & 's0 i64, $return: &out 's1 & 's2 i64) {
  entry:
    unborrow y;
    $return.* = copy x;
    unborrow $return;
    unborrow x;
    return
}
