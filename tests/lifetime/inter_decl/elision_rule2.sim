# Generalized elision rule 2: every synthesized output-position
# lifetime is outlived by every input-position lifetime. Single-
# input case = Rust's rule 2 (output = input); multi-input case =
# output ≤ intersection of inputs. Axioms live on
# Function::signature_outlives.

# ---------- single-input ref, single output ref ----------

fn identity(r: &i64, $return: &out &i64) {
  entry:
    $return.* = copy r;
    return
}

# ---------- multi-input, output from either arg ----------

fn pick_first(x: &i64, y: &i64, $return: &out &i64) {
  entry:
    $return.* = copy x;
    return
}

fn pick_second(x: &i64, y: &i64, $return: &out &i64) {
  entry:
    $return.* = copy y;
    return
}

# ---------- one arg has a declared lifetime, one is elided ----------

# Rule: elided output constrained by every input, whether declared
# or synthesized. `'a outlives out` AND `'s0 outlives out`.
fn<'a> mixed_elision(x: &'a i64, y: &i64, $return: &out &i64) {
  entry:
    $return.* = copy x;
    return
}
