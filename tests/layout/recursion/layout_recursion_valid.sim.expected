struct PlainStruct {
  x: i64
  y: i64
}

struct<'s0> StructRefSelf {
  next: &mut 's0 StructRefSelf
}

enum<'s0> EnumRefSelf {
  Nil: unit
  Cons: &mut 's0 EnumRefSelf
}

struct<'s0> MutualA {
  b: &mut 's0 MutualB
}

struct<'s0> MutualB {
  a: &mut 's0 MutualA
}

struct StructFnSelf {
  f: fn(StructFnSelf)
}
