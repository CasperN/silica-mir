extern fn set_i64(r: &out i64, v: i64);

fn read_const_index() {
  a: [i64; 3];
  x: i64;
  entry:
    a = [10, 20, 30];
    x = copy a[1];
    drop x;
    drop a;
    return
}

fn read_dynamic_index(i: i64) {
  a: [i64; 3];
  x: i64;
  entry:
    a = [10, 20, 30];
    x = copy a[copy i];
    drop x;
    drop a;
    drop i;
    return
}

fn out_borrow_dynamic_uninit(i: i64) {
  a: [i64; 3];
  r: &out i64;
  entry:
    r = &out a[copy i];
    call set_i64(move r, 1);
    drop i;
    return
}

fn const_slot_isolation() {
  a: [i64; 3];
  r: &mut i64;
  x: i64;
  y: i64;
  entry:
    a = [10, 20, 30];
    r = &mut a[0];
    x = copy a[1];
    y = copy r.*;
    unborrow r;
    drop y;
    drop x;
    drop a;
    return
}
