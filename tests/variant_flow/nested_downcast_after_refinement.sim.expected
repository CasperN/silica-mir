enum Sub: Copy + Drop {
  S1: unit
  S2: unit
}

struct Wrap: Copy + Drop {
  inner: Sub
}

enum Outer: Copy + Drop {
  X: Wrap
  Y: unit
}

fn f(o: Outer) {
  entry:
    switchEnum(o) [X: x_lbl, Y: y_lbl]
  x_lbl:
    switchEnum(o as X.inner) [S1: s1, S2: s2]
  y_lbl:
    drop o;
    return
  s1:
    drop o;
    return
  s2:
    drop o;
    return
}
