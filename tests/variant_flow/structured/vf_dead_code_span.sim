# This fixture pins the clean-run behavior when a switchEnum arm is statically
# dead but not falsely-unreachable. Assigning o = Option::None before the
# switch makes the Some arm dead code; the checker must accept the function
# without emitting SwitchArmFalselyUnreachable.

enum Option: Copy + Drop { None: unit Some: i64 }

fn vf_dead_code_span() {
  o: Option;
  entry:
    o = Option::None(unit);
    switchEnum(o) [None: n, Some: s]
  n: return
  s: return
}
