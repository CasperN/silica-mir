struct P: Copy + Drop {
  x: i64
  y: i64
}

struct Box: Drop + Move {
  val: i64
}

fn<'s0, 's1> use_shared(r: & 's0 i64, $return: &out 's1 i64) {
  entry:
    $return.* = copy r.*;
    unborrow $return;
    unborrow r;
    require_uninit $return;
    require_uninit r;
    return
}

fn<'s0, 's1> use_mut(r: &mut 's0 i64, $return: &out 's1 i64) {
  entry:
    $return.* = copy r.*;
    unborrow $return;
    unborrow r;
    require_uninit $return;
    require_uninit r;
    return
}

fn<'s0> take_scalar(y: i64, $return: &out 's0 i64) {
  entry:
    $return.* = copy y;
    unborrow $return;
    require_uninit $return;
    drop y;
    require_uninit y;
    return
}

fn<'s0> shared_of_init(x: i64, $return: &out 's0 i64) {
  _temp_0: & i64;
  _temp_1: &out i64;
  entry:
    _temp_0 = & x;
    _temp_1 = &out $return.*;
    call use_shared(move _temp_0, move _temp_1);
    unborrow $return;
    require_uninit _temp_1;
    require_uninit _temp_0;
    require_uninit $return;
    drop x;
    require_uninit x;
    return
}

fn<'s0> mut_of_init(x: i64, $return: &out 's0 i64) {
  y: i64;
  _temp_0: &mut i64;
  _temp_1: &out i64;
  entry:
    y = copy x;
    _temp_0 = &mut y;
    _temp_1 = &out $return.*;
    call use_mut(move _temp_0, move _temp_1);
    unborrow $return;
    require_uninit _temp_1;
    require_uninit _temp_0;
    drop y;
    require_uninit y;
    require_uninit $return;
    drop x;
    require_uninit x;
    return
}

fn<'s0> mut_of_init_field_of_partial($return: &out 's0 i64) {
  p: P;
  _temp_0: unit;
  r: &mut i64;
  v: i64;
  _temp_1: unit;
  entry:
    p.x = 1;
    _temp_0 = unit;
    drop _temp_0;
    require_uninit _temp_0;
    r = &mut p.x;
    v = copy r.*;
    unborrow r;
    p.y = 2;
    _temp_1 = unit;
    drop _temp_1;
    require_uninit _temp_1;
    $return.* = copy v;
    unborrow $return;
    drop v;
    require_uninit v;
    require_uninit r;
    drop p;
    require_uninit p;
    require_uninit $return;
    return
}

fn<'s0> out_of_never_init($return: &out 's0 i64) {
  x: i64;
  r: &out i64;
  _temp_0: unit;
  entry:
    r = &out x;
    r.* = 42;
    unborrow r;
    _temp_0 = unit;
    drop _temp_0;
    require_uninit _temp_0;
    $return.* = copy x;
    unborrow $return;
    require_uninit r;
    drop x;
    require_uninit x;
    require_uninit $return;
    return
}

fn<'s0> out_of_init_drop_type(x: i64, $return: &out 's0 i64) {
  y: i64;
  r: &out i64;
  _temp_0: unit;
  entry:
    y = copy x;
    drop y;
    r = &out y;
    r.* = 2;
    unborrow r;
    _temp_0 = unit;
    drop _temp_0;
    require_uninit _temp_0;
    $return.* = copy y;
    unborrow $return;
    require_uninit r;
    drop y;
    require_uninit y;
    require_uninit $return;
    drop x;
    require_uninit x;
    return
}

fn<'s0> deinit_of_init(b: Box, $return: &out 's0 Box) {
  owned: Box;
  r: &drop Box;
  taken: Box;
  entry:
    owned = move b;
    r = &drop owned;
    taken = move r.*;
    unborrow r;
    $return.* = move taken;
    unborrow $return;
    require_uninit taken;
    require_uninit r;
    require_uninit owned;
    require_uninit $return;
    require_uninit b;
    return
}

fn uninit_of_never_init() {
  _temp_0: unit;
  x: i64;
  r: &uninit i64;
  entry:
    r = &uninit x;
    unborrow r;
    _temp_0 = unit;
    require_uninit r;
    require_uninit x;
    drop _temp_0;
    require_uninit _temp_0;
    return
}
