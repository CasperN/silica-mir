struct Unit0: Copy + Drop {
}

extern fn take_two(a: i64, b: i64);

fn param_starts_init(x: i64) {
  y: i64;
  entry:
    y = copy x;
    drop y;
    drop x;
    return
}

fn write_then_read() {
  x: i64;
  y: i64;
  entry:
    x = 42;
    y = copy x;
    drop y;
    drop x;
    return
}

fn empty_struct_local_starts_init() {
  u: Unit0;
  v: Unit0;
  entry:
    drop v;
    v = copy u;
    drop v;
    drop u;
    return
}

fn reassign_after_move(x: i64) {
  y: i64;
  z: i64;
  entry:
    y = move x;
    x = 42;
    z = copy x;
    drop z;
    drop y;
    drop x;
    return
}

fn call_args_copy_then_move(x: i64) {
  entry:
    call take_two(copy x, move x);
    return
}
