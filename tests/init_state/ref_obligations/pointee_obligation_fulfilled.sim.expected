struct P: Copy + Drop {
  x: i64
  y: i64
}

enum E: Copy + Drop {
  A: i64
  B: unit
}

struct<T: Copy + Drop> Box: Copy + Drop {
  inner: T
}

enum<T: Copy + Drop> Option: Copy + Drop {
  None: unit
  Some: T
}

fn<'s0> out_scalar(r: &out 's0 i64) {
  entry:
    r.* = 42;
    unborrow r;
    return
}

fn<'s0> out_struct(src: P, r: &out 's0 P) {
  entry:
    r.* = move src;
    unborrow r;
    return
}

fn<'s0> out_enum(r: &out 's0 E) {
  entry:
    r.* = E::A(42);
    unborrow r;
    return
}

fn<'s0> out_array(r: &out 's0 [i64; 3]) {
  entry:
    r.* = [1, 2, 3];
    unborrow r;
    return
}

fn<'s0, T: Copy + Drop> out_param(src: T, r: &out 's0 T) {
  entry:
    r.* = move src;
    unborrow r;
    return
}

fn<'s0, T: Copy + Drop> out_generic_struct(src: Box<T>, r: &out 's0 Box<T>) {
  entry:
    r.* = move src;
    unborrow r;
    return
}

fn<'s0, T: Copy + Drop> out_generic_enum(src: Option<T>, r: &out 's0 Option<T>) {
  entry:
    r.* = move src;
    unborrow r;
    return
}

fn<'s0> out_struct_field_by_field(r: &out 's0 P) {
  entry:
    r.*.x = 1;
    r.*.y = 2;
    unborrow r;
    return
}

fn<'s0> out_array_slot_by_slot(r: &out 's0 [i64; 3]) {
  entry:
    r.*[0] = 1;
    r.*[1] = 2;
    r.*[2] = 3;
    unborrow r;
    return
}

fn<'s0> drop_struct_field_by_field(r: &drop 's0 P) {
  x: i64;
  y: i64;
  entry:
    x = move r.*.x;
    y = move r.*.y;
    unborrow r;
    drop x;
    drop y;
    return
}

fn<'s0> drop_scalar(r: &drop 's0 i64) {
  x: i64;
  entry:
    x = move r.*;
    unborrow r;
    drop x;
    return
}

fn<'s0> drop_struct(r: &drop 's0 P) {
  p: P;
  entry:
    p = move r.*;
    unborrow r;
    drop p;
    return
}

fn<'s0> drop_enum(r: &drop 's0 E) {
  e: E;
  entry:
    e = move r.*;
    unborrow r;
    drop e;
    return
}

fn<'s0> drop_array(r: &drop 's0 [i64; 3]) {
  a: [i64; 3];
  entry:
    a = move r.*;
    unborrow r;
    drop a;
    return
}

fn<'s0, T: Copy + Drop> drop_param(r: &drop 's0 T) {
  x: T;
  entry:
    x = move r.*;
    unborrow r;
    drop x;
    return
}

fn<'s0, T: Copy + Drop> drop_generic_struct(r: &drop 's0 Box<T>) {
  b: Box<T>;
  entry:
    b = move r.*;
    unborrow r;
    drop b;
    return
}

fn<'s0> mut_scalar(r: &mut 's0 i64) {
  entry:
    unborrow r;
    return
}

fn<'s0> mut_struct(r: &mut 's0 P) {
  entry:
    unborrow r;
    return
}

fn<'s0> mut_array(r: &mut 's0 [i64; 3]) {
  entry:
    unborrow r;
    return
}

fn<'s0, T: Copy + Drop> mut_param(r: &mut 's0 T) {
  entry:
    unborrow r;
    return
}

fn<'s0, T: Copy + Drop> mut_generic_struct(r: &mut 's0 Box<T>) {
  entry:
    unborrow r;
    return
}

fn<'s0> uninit_scalar(r: &uninit 's0 i64) {
  entry:
    unborrow r;
    return
}

fn<'s0> uninit_struct(r: &uninit 's0 P) {
  entry:
    unborrow r;
    return
}

fn<'s0> uninit_array(r: &uninit 's0 [i64; 3]) {
  entry:
    unborrow r;
    return
}

fn<'s0, T: Copy + Drop> uninit_param(r: &uninit 's0 T) {
  entry:
    unborrow r;
    return
}
