struct P: Copy + Drop {
  x: i64
  y: i64
}

struct Inner: Copy + Drop {
  a: i64
  b: i64
}

struct Outer: Copy + Drop {
  i: Inner
  c: i64
}

struct Box: Drop + Move {
  val: i64
}

struct Pair: Drop + Move {
  b: Box
  c: Box
}

struct BigOuter: Drop + Move {
  p: Pair
  tag: i64
}

fn<'s0> struct_field_by_field($return: &out 's0 i64) {
  p: P;
  _temp_0: unit;
  _temp_1: unit;
  entry:
    p.x = 1;
    _temp_0 = unit;
    drop _temp_0;
    require_uninit _temp_0;
    p.y = 2;
    _temp_1 = unit;
    drop _temp_1;
    require_uninit _temp_1;
    $return.* = copy p.x;
    unborrow $return;
    drop p;
    require_uninit p;
    require_uninit $return;
    return
}

fn<'s0> nested_struct_leaf_by_leaf($return: &out 's0 i64) {
  o: Outer;
  _temp_0: unit;
  _temp_1: unit;
  _temp_2: unit;
  entry:
    o.i.a = 1;
    _temp_0 = unit;
    drop _temp_0;
    require_uninit _temp_0;
    o.i.b = 2;
    _temp_1 = unit;
    drop _temp_1;
    require_uninit _temp_1;
    o.c = 3;
    _temp_2 = unit;
    drop _temp_2;
    require_uninit _temp_2;
    $return.* = copy o.i.a;
    unborrow $return;
    drop o;
    require_uninit o;
    require_uninit $return;
    return
}

fn<'s0> array_slot_by_slot($return: &out 's0 i64) {
  a: [i64; 3];
  _temp_0: unit;
  _temp_1: unit;
  _temp_2: unit;
  entry:
    a[0] = 1;
    _temp_0 = unit;
    drop _temp_0;
    require_uninit _temp_0;
    a[1] = 2;
    _temp_1 = unit;
    drop _temp_1;
    require_uninit _temp_1;
    a[2] = 3;
    _temp_2 = unit;
    drop _temp_2;
    require_uninit _temp_2;
    $return.* = copy a[1];
    unborrow $return;
    drop a;
    require_uninit a;
    require_uninit $return;
    return
}

fn<'s0> whole_struct_overwrite_from_partial(src: P, $return: &out 's0 i64) {
  p: P;
  _temp_0: unit;
  _temp_1: unit;
  entry:
    p.x = 1;
    _temp_0 = unit;
    drop _temp_0;
    require_uninit _temp_0;
    p = move src;
    _temp_1 = unit;
    drop _temp_1;
    require_uninit _temp_1;
    $return.* = copy p.y;
    unborrow $return;
    drop p;
    require_uninit p;
    require_uninit $return;
    require_uninit src;
    return
}

fn move_one_field_leaves_other_init(p: Pair) {
  _temp_0: unit;
  taken: Box;
  remaining: Box;
  entry:
    taken = move p.b;
    remaining = move p.c;
    _temp_0 = unit;
    drop remaining;
    require_uninit remaining;
    drop taken;
    require_uninit taken;
    drop _temp_0;
    require_uninit _temp_0;
    require_uninit p;
    return
}

fn nested_move_inner_leaf(o: BigOuter) {
  _temp_0: unit;
  inner_taken: Box;
  inner_kept: Box;
  tag: i64;
  entry:
    inner_taken = move o.p.b;
    inner_kept = move o.p.c;
    tag = copy o.tag;
    _temp_0 = unit;
    drop tag;
    require_uninit tag;
    drop inner_kept;
    require_uninit inner_kept;
    drop inner_taken;
    require_uninit inner_taken;
    drop _temp_0;
    require_uninit _temp_0;
    drop o.tag;
    require_uninit o;
    return
}
