# Full (cur, post) transition cycle through *r: move-out then
# write-back, using the freed pointee value.
extern fn use_num(n: i64);
extern fn sink(r: &mut i64);
fn f(x: i64) {
  r: &mut i64;
  y: i64;
  entry:
    r = &mut x;
    y = move r.*;
    r.* = 42;
    call use_num(move y);
    call sink(move r);
    return
}
