# Two sequential loops in one function. State between them
# should reset cleanly.
extern fn noop();
fn f(b: bool) {
  entry:
    goto head1
  head1:
    branch(copy b) [true: body1, false: done1]
  body1:
    call noop();
    goto head1
  done1:
    goto head2
  head2:
    branch(copy b) [true: body2, false: done2]
  body2:
    call noop();
    goto head2
  done2:
    return
}
