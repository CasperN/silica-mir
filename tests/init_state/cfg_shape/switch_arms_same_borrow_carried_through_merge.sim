# Two switchEnum arms create the same borrow; the loan carries
# through the merge and is consumed once.
enum Sel: Copy + Drop { A: unit B: unit }
extern fn sink(r: &mut i64);
fn f(o: Sel, x: i64) {
  r: &mut i64;
  entry:
    switchEnum(o) [A: a_arm, B: b_arm]
  a_arm:
    r = &mut x;
    goto merge
  b_arm:
    r = &mut x;
    goto merge
  merge:
    call sink(move r);
    return
}
