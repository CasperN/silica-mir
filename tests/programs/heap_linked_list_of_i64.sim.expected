extern fn malloc_node(size: i64, $return: &out *Node);

extern fn free_node(p: *Node);

struct Node: Move {
  value: i64
  next: List
}

enum List: Move {
  Empty: unit
  Cons: *Node
}

fn list_empty($return: &out List) {
  entry:
    $return.* = List::Empty(unit);
    unborrow $return;
    return
}

fn list_cons(value: i64, tail: List, $return: &out List) {
  p: *Node;
  p_out: &out *Node;
  entry:
    p_out = &out p;
    call malloc_node(24, move p_out);
    p.*.value = copy value;
    p.*.next = move tail;
    $return.* = List::Cons(move p);
    unborrow $return;
    drop value;
    return
}

fn list_free(list: List) {
  p: *Node;
  tail: List;
  u: unit;
  entry:
    switchEnum(list) [Empty: e_arm, Cons: c_arm]
  e_arm:
    u = move list as Empty;
    drop u;
    return
  c_arm:
    p = move list as Cons;
    tail = move p.*.next;
    call free_node(move p);
    call list_free(move tail);
    return
}

fn list_sum(list: & List, $return: &out i64) {
  p: *Node;
  s: i64;
  s_out: &out i64;
  add_out: &out i64;
  v: i64;
  next_ref: & List;
  entry:
    switchEnum(list.*) [Empty: entry__to__e_arm, Cons: c_arm]
  entry__to__e_arm:
    unborrow list;
    goto e_arm
  e_arm:
    $return.* = 0;
    unborrow $return;
    return
  c_arm:
    p = copy list.* as Cons;
    unborrow list;
    v = copy p.*.value;
    s_out = &out s;
    next_ref = & p.*.next;
    call list_sum(move next_ref, move s_out);
    add_out = &out $return.*;
    call $i64_add(copy v, copy s, move add_out);
    unborrow $return;
    drop v;
    drop s;
    drop p;
    return
}

fn main(exit: &out i32) {
  l0: List;
  l1: List;
  l2: List;
  l3: List;
  l0_out: &out List;
  l1_out: &out List;
  l2_out: &out List;
  l3_out: &out List;
  s: i64;
  s_out: &out i64;
  s_trunc_out: &out i32;
  l3_ref: & List;
  entry:
    l0_out = &out l0;
    call list_empty(move l0_out);
    l1_out = &out l1;
    call list_cons(3, move l0, move l1_out);
    l2_out = &out l2;
    call list_cons(2, move l1, move l2_out);
    l3_out = &out l3;
    call list_cons(1, move l2, move l3_out);
    s_out = &out s;
    l3_ref = & l3;
    call list_sum(move l3_ref, move s_out);
    call list_free(move l3);
    s_trunc_out = &out exit.*;
    call $i64_to_i32(copy s, move s_trunc_out);
    unborrow exit;
    drop s;
    return
}
