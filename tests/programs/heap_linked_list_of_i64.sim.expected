extern fn malloc_node(size: i64, $return: &out 's0 *Node);

extern fn free_node(p: *Node);

struct Node: Move {
  value: i64
  next: List
}

enum List: Move {
  Empty: unit
  Cons: *Node
}

fn<'s0> list_empty($return: &out 's0 List) {
  entry:
    $return.* = List::Empty(unit);
    unborrow $return;
    return
}

fn<'s0> list_cons(value: i64, tail: List, $return: &out 's0 List) {
  p: *Node;
  _temp_0: &out *Node;
  _temp_1: unit;
  _temp_2: unit;
  _temp_3: unit;
  entry:
    _temp_0 = &out p;
    call malloc_node(24, move _temp_0);
    p.*.value = copy value;
    _temp_2 = unit;
    p.*.next = move tail;
    _temp_3 = unit;
    _temp_1 = unit;
    $return.* = List::Cons(copy p);
    unborrow $return;
    drop _temp_3;
    drop _temp_2;
    drop _temp_1;
    drop p;
    drop value;
    return
}

fn list_free(list: List) {
  _temp_0: unit;
  u: unit;
  p: *Node;
  tail: List;
  _temp_1: unit;
  entry:
    switchEnum(list) [Empty: switch_Empty_0, Cons: switch_Cons_1]
  switch_Empty_0:
    u = move list as Empty;
    _temp_0 = copy u;
    goto switch_Empty_0__to__switch_merge_2
  switch_Empty_0__to__switch_merge_2:
    drop u;
    goto switch_merge_2
  switch_Cons_1:
    p = move list as Cons;
    tail = move p.*.next;
    call free_node(copy p);
    _temp_1 = unit;
    call list_free(move tail);
    _temp_0 = unit;
    goto switch_Cons_1__to__switch_merge_2
  switch_Cons_1__to__switch_merge_2:
    drop p;
    drop _temp_1;
    goto switch_merge_2
  switch_merge_2:
    drop _temp_0;
    return
}

fn<'s0, 's1> list_sum(list: & 's0 List, $return: &out 's1 i64) {
  _: unit;
  p: *Node;
  _temp_0: i64;
  _temp_1: & List;
  _temp_2: &out i64;
  _temp_3: &out i64;
  entry:
    switchEnum(list.*) [Empty: switch_Empty_0, Cons: switch_Cons_1]
  switch_Empty_0:
    _ = copy list.* as Empty;
    unborrow list;
    $return.* = 0;
    unborrow $return;
    goto switch_Empty_0__to__switch_merge_2
  switch_Empty_0__to__switch_merge_2:
    drop _;
    goto switch_merge_2
  switch_Cons_1:
    p = copy list.* as Cons;
    unborrow list;
    _temp_1 = & p.*.next;
    _temp_2 = &out _temp_0;
    call list_sum(move _temp_1, move _temp_2);
    _temp_3 = &out $return.*;
    call $i64_add(copy p.*.value, move _temp_0, move _temp_3);
    unborrow $return;
    goto switch_Cons_1__to__switch_merge_2
  switch_Cons_1__to__switch_merge_2:
    drop p;
    goto switch_merge_2
  switch_merge_2:
    return
}

fn<'s0> main(exit: &out 's0 i32) {
  _temp_0: unit;
  l0: List;
  _temp_1: &out List;
  l1: List;
  _temp_2: &out List;
  l2: List;
  _temp_3: &out List;
  l3: List;
  _temp_4: &out List;
  s: i64;
  _temp_5: & List;
  _temp_6: &out i64;
  _temp_7: unit;
  _temp_8: unit;
  _temp_9: i32;
  _temp_10: &out i32;
  entry:
    _temp_1 = &out l0;
    call list_empty(move _temp_1);
    _temp_2 = &out l1;
    call list_cons(3, move l0, move _temp_2);
    _temp_3 = &out l2;
    call list_cons(2, move l1, move _temp_3);
    _temp_4 = &out l3;
    call list_cons(1, move l2, move _temp_4);
    _temp_5 = & l3;
    _temp_6 = &out s;
    call list_sum(move _temp_5, move _temp_6);
    call list_free(move l3);
    _temp_7 = unit;
    _temp_10 = &out _temp_9;
