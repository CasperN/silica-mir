fn double(x: i64, out: &out i64) {
  add_out: &out i64;
  entry:
    add_out = &out out.*;
    call $i64_add(copy x, copy x, move add_out);
    unborrow out;
    drop x;
    return
}

fn call_it(f: fn(i64, &out i64), x: i64, out: &out i64) {
  fwd_out: &out i64;
  entry:
    fwd_out = &out out.*;
    call copy f(copy x, move fwd_out);
    unborrow out;
    drop x;
    drop f;
    return
}

fn main(exit: &out i32) {
  r: i64;
  r_out: &out i64;
  trunc_out: &out i32;
  entry:
    r_out = &out r;
    call call_it(double, 21, move r_out);
    trunc_out = &out exit.*;
    call $i64_to_i32(copy r, move trunc_out);
    unborrow exit;
    drop r;
    return
}
