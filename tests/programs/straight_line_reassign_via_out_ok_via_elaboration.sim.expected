fn f(a: i64, b: i64, c: i64, out: &out i64) {
  r: i64;
  r_out: &out i64;
  entry:
    r_out = &out r;
    call $i64_add(copy a, copy b, move r_out);
    drop r;
    r_out = &out r;
    call $i64_mul(copy a, copy c, move r_out);
    out.* = copy r;
    unborrow out;
    drop r;
    drop c;
    drop b;
    drop a;
    return
}
