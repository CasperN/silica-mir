enum Inner: Copy + Drop {
  X: i64
  Y: i64
}

enum Outer: Copy + Drop {
  A: Inner
  B: i64
}

fn<'s0> nested_downcast(o: Outer, $return: &out 's0 i64) {
  inner: Inner;
  x: i64;
  y: i64;
  b: i64;
  entry:
    switchEnum(o) [A: switch_A_0, B: switch_B_1]
  switch_A_0:
    inner = copy o as A;
    switchEnum(inner) [X: switch_X_3, Y: switch_Y_4]
  switch_X_3:
    x = copy inner as X;
    $return.* = copy x;
    unborrow $return;
    drop x;
    require_uninit x;
    goto switch_merge_5
  switch_Y_4:
    y = copy inner as Y;
    $return.* = copy y;
    unborrow $return;
    drop y;
    require_uninit y;
    goto switch_merge_5
  switch_merge_5:
    drop inner;
    require_uninit inner;
    goto switch_merge_2
  switch_B_1:
    b = copy o as B;
    $return.* = copy b;
    unborrow $return;
    drop b;
    require_uninit b;
    goto switch_merge_2
  switch_merge_2:
    require_uninit $return;
    drop o;
    require_uninit o;
    return
}

enum Tag: Copy + Drop {
  Zero: unit
  Pos: i64
  Neg: i64
}

fn<'s0> to_i64(t: Tag, $return: &out 's0 i64) {
  _: unit;
  p: i64;
  n: i64;
  _temp_0: &out i64;
  entry:
    switchEnum(t) [Zero: switch_Zero_0, Pos: switch_Pos_1, Neg: switch_Neg_2]
  switch_Zero_0:
    _ = copy t as Zero;
    $return.* = 0;
    unborrow $return;
    drop _;
    require_uninit _;
    goto switch_merge_3
  switch_Pos_1:
    p = copy t as Pos;
    $return.* = copy p;
    unborrow $return;
    drop p;
    require_uninit p;
    goto switch_merge_3
  switch_Neg_2:
    n = copy t as Neg;
    _temp_0 = &out $return.*;
    call $i64_neg(copy n, move _temp_0);
    unborrow $return;
    require_uninit _temp_0;
    drop n;
    require_uninit n;
    goto switch_merge_3
  switch_merge_3:
    require_uninit $return;
    drop t;
    require_uninit t;
    return
}

fn<'s0> sum_two_tags(a: [Tag; 2], $return: &out 's0 i64) {
  _temp_0: i64;
  _temp_1: &out i64;
  _temp_2: i64;
  _temp_3: &out i64;
  _temp_4: &out i64;
  entry:
    _temp_1 = &out _temp_0;
    call to_i64(move a[0], move _temp_1);
    _temp_3 = &out _temp_2;
    call to_i64(move a[1], move _temp_3);
    _temp_4 = &out $return.*;
    call $i64_add(move _temp_0, move _temp_2, move _temp_4);
    unborrow $return;
    require_uninit _temp_4;
    require_uninit _temp_3;
    require_uninit _temp_2;
    require_uninit _temp_1;
    require_uninit _temp_0;
    require_uninit $return;
    require_uninit a;
    return
}

enum Which: Copy + Drop {
  A: unit
  B: unit
}

fn<'s0> asymmetric_ref_use(r: &mut 's0 i64, w: Which) {
  _temp_0: unit;
  a: unit;
  observed: i64;
  b: unit;
  entry:
    switchEnum(w) [A: switch_A_0, B: entry__to__switch_B_1]
  entry__to__switch_B_1:
    unborrow r;
    goto switch_B_1
  switch_A_0:
    a = copy w as A;
    observed = copy r.*;
    unborrow r;
    _temp_0 = unit;
    drop observed;
    require_uninit observed;
    drop a;
    require_uninit a;
    goto switch_merge_2
  switch_B_1:
    b = copy w as B;
    _temp_0 = unit;
    drop b;
    require_uninit b;
    goto switch_merge_2
  switch_merge_2:
    drop _temp_0;
    require_uninit _temp_0;
    drop w;
    require_uninit w;
    require_uninit r;
    return
}
