# HLL iterative loops — end-to-end programs that only compile once
# drop-elab's cross-edge insertion runs at every join (not just at
# return-block predecessors). Before that fix, every `if c { break }`
# inside `loop` leaked the block-local unit temps at return.
#
# The elaborated MIR pinned below is the drop-elab witness — each
# back-edge splits into an `if_merge__to__loop_start` block that
# drops the loop-body Init temps before re-entering the head.

fn sum_to_n(n: i64) -> i64 {
  let mut acc = 0;
  let mut i = 1;
  loop {
    if i > n { break }
    acc = acc + i;
    i = i + 1;
  }
  acc
}

# Fibonacci — HLL sibling of `tests/programs/iterative_fibonacci_loop.sim`.
# Same shape: two accumulators updated per iteration, exits when the
# counter reaches `n`. Hoisted `next` out of the loop body — HLL
# `let` currently binds at fn scope, so a fresh `let next = a + b;`
# each iteration would trip `&out next` on the second iteration's
# re-borrow.
fn fib(n: i64) -> i64 {
  let mut a = 0;
  let mut b = 1;
  let mut i = 0;
  let mut next = 0;
  loop {
    if i >= n { break }
    next = a + b;
    a = b;
    b = next;
    i = i + 1;
  }
  a
}
