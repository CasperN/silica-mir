fn fib(n: i64, out: &out i64) {
  a: i64;
  b: i64;
  i: i64;
  i_tmp: i64;
  done_tmp: bool;
  done_out: &out bool;
  next_tmp: i64;
  next_out: &out i64;
  inc_out: &out i64;
  entry:
    a = 0;
    b = 1;
    i = 0;
    goto head
  head:
    done_out = &out done_tmp;
    call $i64_ge(copy i, copy n, move done_out);
    branch(move done_tmp) [true: exit, false: body]
  body:
    next_out = &out next_tmp;
    call $i64_add(copy a, copy b, move next_out);
    drop a;
    a = copy b;
    drop b;
    b = move next_tmp;
    inc_out = &out i_tmp;
    call $i64_add(copy i, 1, move inc_out);
    drop i;
    i = move i_tmp;
    goto head
  exit:
    out.* = copy a;
    unborrow out;
    drop i;
    drop b;
    drop a;
    drop n;
    return
}
