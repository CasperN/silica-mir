
        enum Which: Copy + Drop { A: unit B: unit }
        fn f(r: &mut i64, w: Which) {
          consumed: i64;
          entry:
            switchEnum(w) [A: a_arm, B: b_arm]
          a_arm:
            consumed = move r.*;
            r.* = 99i64;
            goto join
          b_arm:
            goto join
          join:
            return
        }
        