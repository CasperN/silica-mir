# HLL sibling of `heap_linked_list_of_i64.sim`. Same shape, HLL surface:
# `extern fn` (Silica ABI, sret via `-> R`), unsafe raw-pointer deref
# through a linear enum, recursion consuming the list (list_free), and
# recursion borrowing it (list_sum).
#
# HLL match on a Move-only enum lowers to `move scrut as V` for owned
# scrutinees, so the whole enum is consumed via enum-atomicity and
# list_free type-checks. Borrowed scrutinees (list_sum's `list.*`
# match) still copy — moving through a shared ref would be a
# use-through-borrow error.
#
# `extern fn` uses bare Silica ABI here. When MIR codegen honors the
# ABI string (punchlist), a real C libc `malloc` would move to
# `extern "C" fn malloc(size: u64) -> *u8;` — but that also needs
# `as` casts, which are the next follow-up.

extern fn malloc_node(size: i64) -> *Node;
extern fn free_node(p: *Node);

# Values are i32 so the sum flows into `exit: &out i32` without a
# truncation intrinsic (HLL doesn't have `as` casts yet).
struct Node: Move { value: i32, next: List }
enum List: Move { Empty: unit, Cons: *Node }

fn list_empty() -> List {
  List::Empty(unit)
}

# Consumes `tail` (Move-only) into the newly-heap-allocated node.
fn list_cons(value: i32, tail: List) -> List {
  let p: *Node = malloc_node(24i64);
  unsafe {
    p.*.value = value;
    p.*.next = tail;
  }
  List::Cons(p)
}

# Recursive free. The `Empty` arm binds the payload (unit) into a
# local — `move list as Empty` consumes the whole scrutinee via
# enum-atomicity. The `Cons` arm extracts the raw pointer with `move`
# too, reads the tail through unsafe deref, frees the node, and
# tail-recurses on the tail.
fn list_free(list: List) {
  list match {
    Empty(u) => u,
    Cons(p) => {
      let tail: List = unsafe { p.*.next };
      free_node(p);
      list_free(tail)
    },
  }
}

# Recursive sum via a shared borrow — the list is not consumed. Reads
# `value` and `next` through the raw pointer inside `Cons`. Match on
# `list.*` (dereffed shared ref) copies the payload rather than moving
# — moving out through a shared ref would violate the borrow.
fn list_sum(list: &List) -> i32 {
  list.* match {
    Empty(_) => 0i32,
    Cons(p) => unsafe { (p.*.value + list_sum(&p.*.next)) },
  }
}

# Build [1, 2, 3], sum via borrow, free the list, write sum → exit.
# Runtime exit code is 6.
fn main(exit: &out i32) {
  let l0: List = list_empty();
  let l1: List = list_cons(3i32, l0);
  let l2: List = list_cons(2i32, l1);
  let l3: List = list_cons(1i32, l2);
  let s: i32 = list_sum(&l3);
  list_free(l3);
  exit.* = s;
}
