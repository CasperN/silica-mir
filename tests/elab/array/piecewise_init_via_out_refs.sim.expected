extern fn set_i64(r: &out i64, v: i64);

fn f() {
  a: [i64; 3];
  r0: &out i64;
  r1: &out i64;
  r2: &out i64;
  entry:
    r0 = &out a[0];
    call set_i64(move r0, 10);
    r1 = &out a[1];
    call set_i64(move r1, 20);
    r2 = &out a[2];
    call set_i64(move r2, 30);
    drop a;
    return
}
