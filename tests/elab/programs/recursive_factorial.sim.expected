fn fact(n: i64, out: &out i64) {
  base: bool;
  bo: &out bool;
  sub: i64;
  sub_out: &out i64;
  sub_result: i64;
  rec_out: &out i64;
  mul_out: &out i64;
  entry:
    bo = &out base;
    call $i64_le(copy n, 1, move bo);
    branch(copy base) [true: base_arm, false: rec_arm]
  base_arm:
    out.* = 1;
    unborrow out;
    drop base;
    drop n;
    return
  rec_arm:
    sub_out = &out sub;
    call $i64_sub(copy n, 1, move sub_out);
    rec_out = &out sub_result;
    call fact(copy sub, move rec_out);
    mul_out = &out out.*;
    call $i64_mul(copy n, copy sub_result, move mul_out);
    unborrow out;
    drop sub_result;
    drop sub;
    drop base;
    drop n;
    return
}
