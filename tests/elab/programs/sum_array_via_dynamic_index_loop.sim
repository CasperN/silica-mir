
        fn sum(a: [i64; 4], out: &out i64) {
          sum: i64;
          sum_tmp: i64;
          i: i64;
          i_tmp: i64;
          done_tmp: bool;
          done_out: &out bool;
          slot: i64;
          add_out: &out i64;
          inc_out: &out i64;
          entry:
            sum = 0i64;
            i = 0i64;
            goto head
          head:
            done_out = &out done_tmp;
            call $i64_ge(copy i, 4i64, move done_out);
            branch(move done_tmp) [true: exit, false: body]
          body:
            slot = copy a[copy i];
            add_out = &out sum_tmp;
            call $i64_add(copy sum, copy slot, move add_out);
            sum = move sum_tmp;
            drop slot;
            inc_out = &out i_tmp;
            call $i64_add(copy i, 1i64, move inc_out);
            i = move i_tmp;
            goto head
          exit:
            out.* = copy sum;
            return
        }
        