enum Inner: Copy + Drop {
  X: i64
  Y: i64
}

enum Outer: Copy + Drop {
  A: Inner
  B: i64
}

fn f(o: Outer, out: &out i64) {
  inner: Inner;
  entry:
    switchEnum(o) [A: a_arm, B: b_arm]
  a_arm:
    inner = copy o as A;
    switchEnum(inner) [X: x_arm, Y: y_arm]
  x_arm:
    out.* = copy inner as X;
    unborrow out;
    drop inner;
    drop o;
    return
  y_arm:
    out.* = copy inner as Y;
    unborrow out;
    drop inner;
    drop o;
    return
  b_arm:
    out.* = copy o as B;
    unborrow out;
    drop o;
    return
}
